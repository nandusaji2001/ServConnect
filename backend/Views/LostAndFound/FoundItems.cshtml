@model ServConnect.ViewModels.LostFoundListViewModel
@{
    ViewData["Title"] = "Found Items - Lost & Found";
}

<style>
    :root {
        --primary: #10B981;
        --primary-dark: #059669;
        --primary-light: #34D399;
        --bg-light: #ffffff;
        --bg-section: #f8fafc;
        --bg-card: #ffffff;
        --bg-card-hover: #f9fafb;
        --text-primary: #1f2937;
        --text-secondary: #6b7280;
        --border-color: #e5e7eb;
        --gradient-primary: linear-gradient(135deg, #10B981 0%, #059669 100%);
        --shadow-sm: 0 4px 6px rgba(0, 0, 0, 0.05);
        --shadow-md: 0 10px 25px rgba(0, 0, 0, 0.1);
        --shadow-lg: 0 25px 50px rgba(0, 0, 0, 0.15);
        --shadow-glow: 0 10px 40px rgba(16, 185, 129, 0.3);
    }

    body {
        background: linear-gradient(135deg, #f0fdf4 0%, #ecfdf5 50%, #d1fae5 100%);
        min-height: 100vh;
    }

    .lf-container {
        padding: 20px 15px;
        max-width: 1600px;
        margin: 0 auto;
    }

    .back-btn {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        padding: 10px 20px;
        background: rgba(255, 255, 255, 0.95);
        backdrop-filter: blur(12px);
        color: var(--text-primary);
        border-radius: 50px;
        text-decoration: none;
        font-weight: 500;
        box-shadow: var(--shadow-sm);
        border: 1px solid var(--border-color);
        transition: all 0.3s ease;
        margin-bottom: 20px;
    }

    .back-btn:hover {
        transform: translateX(-5px);
        box-shadow: var(--shadow-md);
        color: var(--primary);
        border-color: var(--primary);
        text-decoration: none;
    }

    .lf-nav-filter-combined {
        background: rgba(255, 255, 255, 0.95);
        backdrop-filter: blur(12px);
        padding: 20px 24px;
        border-radius: 16px;
        margin-bottom: 24px;
        box-shadow: var(--shadow-sm);
    }

    .lf-nav-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 20px;
        padding-bottom: 16px;
        border-bottom: 2px solid var(--border-color);
        flex-wrap: wrap;
        gap: 16px;
    }

    .lf-nav-title {
        font-size: 1.5rem;
        font-weight: 700;
        color: var(--text-primary);
        display: flex;
        align-items: center;
        gap: 10px;
    }

    .lf-nav-links {
        display: flex;
        gap: 10px;
        flex-wrap: wrap;
    }

    .nav-link-btn {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        padding: 10px 18px;
        border-radius: 50px;
        font-weight: 600;
        font-size: 0.85rem;
        text-decoration: none;
        transition: all 0.3s ease;
        border: 2px solid transparent;
    }

    .nav-link-btn.active {
        background: var(--gradient-primary);
        color: white;
        box-shadow: 0 4px 12px rgba(16, 185, 129, 0.3);
    }

    .nav-link-btn.inactive {
        background: rgba(255, 255, 255, 0.8);
        color: var(--text-secondary);
        border-color: var(--border-color);
    }

    .nav-link-btn.inactive:hover {
        background: var(--primary);
        color: white;
        border-color: var(--primary);
        text-decoration: none;
        transform: translateY(-2px);
    }

    .nav-link-btn.primary-action {
        background: var(--gradient-primary);
        color: white;
        box-shadow: var(--shadow-sm);
    }

    .nav-link-btn.primary-action:hover {
        transform: translateY(-2px);
        box-shadow: var(--shadow-glow);
        text-decoration: none;
    }

    .filter-section {
        display: flex;
        align-items: center;
        gap: 16px;
        flex-wrap: wrap;
    }

    .filter-label {
        font-weight: 600;
        color: var(--text-primary);
        font-size: 0.9rem;
        display: flex;
        align-items: center;
        gap: 8px;
        white-space: nowrap;
    }

    .filter-pills {
        display: flex;
        flex-wrap: wrap;
        gap: 8px;
        flex: 1;
    }

    .filter-pill {
        padding: 8px 16px;
        border-radius: 50px;
        font-size: 0.8rem;
        font-weight: 500;
        text-decoration: none;
        transition: all 0.3s ease;
        border: 1px solid var(--border-color);
        background: white;
        color: var(--text-secondary);
    }

    .filter-pill:hover, .filter-pill.active {
        background: var(--gradient-primary);
        color: white;
        border-color: var(--primary);
        text-decoration: none;
        transform: translateY(-2px);
    }

    .items-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
        gap: 24px;
    }

    .item-card {
        background: var(--bg-card);
        border: 1px solid var(--border-color);
        border-radius: 20px;
        overflow: hidden;
        box-shadow: var(--shadow-sm);
        transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
        position: relative;
    }

    .item-card::before {
        content: '';
        position: absolute;
        top: 0;
        left: 0;
        width: 4px;
        height: 100%;
        background: var(--gradient-primary);
        transform: scaleY(0);
        transition: transform 0.3s ease;
    }

    .item-card:hover::before {
        transform: scaleY(1);
    }

    .item-card:hover {
        transform: translateY(-8px);
        background: var(--bg-card-hover);
        border-color: var(--primary);
        box-shadow: var(--shadow-lg);
    }

    .item-image {
        height: 200px;
        background: linear-gradient(135deg, #f0fdf4 0%, #dcfce7 100%);
        display: flex;
        align-items: center;
        justify-content: center;
        position: relative;
        overflow: hidden;
    }

    .item-image img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        transition: transform 0.5s ease;
    }

    .item-card:hover .item-image img {
        transform: scale(1.08);
    }

    .item-image .placeholder-icon {
        font-size: 4rem;
        color: var(--primary);
        opacity: 0.3;
    }

    .item-badges {
        position: absolute;
        top: 12px;
        left: 12px;
        right: 12px;
        display: flex;
        justify-content: space-between;
    }

    .badge-category {
        background: rgba(255, 255, 255, 0.95);
        backdrop-filter: blur(8px);
        color: var(--text-primary);
        padding: 6px 14px;
        border-radius: 20px;
        font-size: 0.8rem;
        font-weight: 600;
    }

    .badge-condition {
        padding: 6px 14px;
        border-radius: 20px;
        font-size: 0.8rem;
        font-weight: 600;
        color: white;
    }

    .badge-condition.good { background: var(--primary); }
    .badge-condition.damaged { background: #EF4444; }
    .badge-condition.used { background: #F59E0B; }

    .item-content {
        padding: 24px;
    }

    .item-title {
        font-size: 1.25rem;
        font-weight: 700;
        color: var(--text-primary);
        margin-bottom: 10px;
        line-height: 1.3;
    }

    .item-description {
        color: var(--text-secondary);
        font-size: 0.9rem;
        line-height: 1.6;
        margin-bottom: 16px;
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
    }

    .item-meta {
        display: flex;
        flex-direction: column;
        gap: 8px;
        padding-top: 16px;
        border-top: 1px solid var(--border-color);
        font-size: 0.85rem;
        color: var(--text-secondary);
    }

    .item-meta i {
        color: var(--primary);
        width: 20px;
    }

    .item-btn {
        width: 100%;
        background: var(--gradient-primary);
        border: none;
        padding: 14px;
        border-radius: 12px;
        color: white;
        font-weight: 600;
        font-size: 0.95rem;
        cursor: pointer;
        margin-top: 16px;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 8px;
        transition: all 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275);
        text-decoration: none;
    }

    .item-btn:hover {
        transform: translateY(-2px);
        box-shadow: var(--shadow-glow);
        color: white;
        text-decoration: none;
    }

    .empty-state {
        text-align: center;
        padding: 80px 20px;
        grid-column: 1 / -1;
    }

    .empty-state i {
        font-size: 5rem;
        color: var(--primary);
        opacity: 0.3;
        margin-bottom: 24px;
    }

    .empty-state h3 {
        font-size: 1.5rem;
        color: var(--text-primary);
        margin-bottom: 12px;
    }

    .empty-state p {
        color: var(--text-secondary);
        max-width: 400px;
        margin: 0 auto 24px;
    }

    .alert {
        border-radius: 16px;
        border: none;
        padding: 16px 24px;
    }

    .alert-success {
        background: linear-gradient(135deg, #f0fdf4 0%, #dcfce7 100%);
        color: var(--primary-dark);
    }

    @@media (max-width: 768px) {
        .lf-nav-header {
            flex-direction: column;
            align-items: flex-start;
        }
        .lf-nav-links {
            width: 100%;
            flex-direction: column;
        }
        .nav-link-btn {
            width: 100%;
            justify-content: center;
        }
        .filter-section {
            flex-direction: column;
            align-items: flex-start;
        }
        .filter-pills {
            width: 100%;
        }
        .items-grid {
            grid-template-columns: 1fr;
        }
    }
</style>

<div class="lf-container">
    <a href="/Home/ExploreServices" class="back-btn">
        <i class="fas fa-arrow-left"></i> Back to Services
    </a>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show mb-4" role="alert">
            <i class="fas fa-check-circle me-2"></i>@TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <div class="lf-nav-filter-combined">
        <div class="lf-nav-header">
            <div class="lf-nav-title">
                <i class="fas fa-search"></i>
                Lost & Found
            </div>
            <div class="lf-nav-links">
                <a asp-action="Index" class="nav-link-btn inactive">
                    <i class="fas fa-exclamation-triangle"></i> Lost Items
                </a>
                <a asp-action="FoundItems" class="nav-link-btn active">
                    <i class="fas fa-search"></i> Found Items
                </a>
                @if (User.Identity?.IsAuthenticated == true)
                {
                    <a asp-action="MyLostItems" class="nav-link-btn inactive">
                        <i class="fas fa-list"></i> My Lost Items
                    </a>
                    <a asp-action="MyFoundItems" class="nav-link-btn inactive">
                        <i class="fas fa-box"></i> My Found Items
                    </a>
                    <a asp-action="MyClaims" class="nav-link-btn inactive">
                        <i class="fas fa-hand-paper"></i> My Claims
                    </a>
                    <a asp-action="ReportFound" class="nav-link-btn primary-action">
                        <i class="fas fa-plus-circle"></i> Report Found
                    </a>
                }
            </div>
        </div>

        <div class="filter-section">
            <div class="filter-label">
                <i class="fas fa-filter"></i> Category:
            </div>
            <div class="filter-pills">
                <a href="@Url.Action("FoundItems")" class="filter-pill @(string.IsNullOrEmpty(Model.CategoryFilter) ? "active" : "")">
                    All Items
                </a>
                @foreach (var cat in ServConnect.Models.LostFoundItemCategory.All)
                {
                    <a href="@Url.Action("FoundItems", new { category = cat })" 
                       class="filter-pill @(Model.CategoryFilter == cat ? "active" : "")">
                        @cat
                    </a>
                }
            </div>
        </div>
    </div>

    <div class="items-grid">
        @if (Model.Items.Count == 0)
        {
            <div class="empty-state">
                <i class="fas fa-inbox"></i>
                <h3>No found items available</h3>
                <p>Be the first to report a found item and help someone find their lost belongings!</p>
                @if (User.Identity?.IsAuthenticated == true)
                {
                    <a asp-action="ReportFound" class="nav-link-btn primary-action">
                        <i class="fas fa-plus-circle"></i> Report Found Item
                    </a>
                }
            </div>
        }
        else
        {
            @foreach (var item in Model.Items)
            {
                <div class="item-card">
                    <div class="item-image">
                        @if (item.Images.Count > 0)
                        {
                            <img src="@item.Images[0]" alt="@item.Title">
                        }
                        else
                        {
                            <i class="fas fa-image placeholder-icon"></i>
                        }
                        <div class="item-badges">
                            <span class="badge-category">@item.Category</span>
                            <span class="badge-condition @item.Condition.ToLower()">@item.Condition</span>
                        </div>
                    </div>
                    <div class="item-content">
                        <h3 class="item-title">@item.Title</h3>
                        <p class="item-description">
                            @(item.Description.Length > 100 ? item.Description.Substring(0, 100) + "..." : item.Description)
                        </p>
                        <div class="item-meta">
                            <div><i class="fas fa-map-marker-alt"></i> @item.FoundLocation</div>
                            <div><i class="fas fa-calendar"></i> Found: @item.FoundDate.ToString("MMM dd, yyyy")</div>
                        </div>
                        <a asp-action="Details" asp-route-id="@item.Id" class="item-btn">
                            <i class="fas fa-eye"></i> View Details
                        </a>
                    </div>
                </div>
            }
        }
    </div>
</div>
