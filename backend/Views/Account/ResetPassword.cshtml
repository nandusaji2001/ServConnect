@using ServConnect.ViewModels;
@model ResetPasswordViewModel;

@{
    ViewData["Title"] = "Reset Password";
    Layout = "~/Views/Shared/_AccountLayout.cshtml";
}

<style>
    html, body {
        margin: 0;
        padding: 0;
        height: 100%;
        overflow-x: hidden;
    }

    body {
        background: url('/images/login_register_bg.png') center/cover no-repeat;
        font-family: 'Avenir', sans-serif;
    }

    .reset-container {
        display: flex;
        justify-content: center;
        align-items: center;
        min-height: 100vh;
        padding: 2rem;
        overflow-y: auto;
        box-sizing: border-box;
    }

    .reset-card {
        background: rgba(255, 255, 255, 0.55);
        border-radius: 20px;
        box-shadow: 0 10px 40px rgba(0, 0, 0, 0.1);
        max-width: 440px;
        width: 100%;
        padding: 48px;
        margin: 20px 0;
        backdrop-filter: blur(5px);
    }

    .brand-header {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 12px;
        margin-bottom: 32px;
    }

    .brand-logo {
        width: 48px;
        height: 48px;
        object-fit: contain;
    }

    .brand-name {
        font-family: 'Fraunces', serif;
        font-size: 24px;
        font-weight: 300;
        color: #1a1a1a;
        margin: 0;
    }

    .reset-title {
        font-family: 'Fraunces', serif;
        font-size: 28px;
        font-weight: 300;
        color: #1a1a1a;
        text-align: center;
        margin-bottom: 8px;
    }

    .reset-subtitle {
        text-align: center;
        color: #6b7280;
        font-size: 15px;
        margin-bottom: 32px;
        font-weight: 300;
    }

    .form-group {
        margin-bottom: 20px;
    }

    .form-group label {
        display: block;
        font-size: 14px;
        font-weight: 300;
        color: #374151;
        margin-bottom: 8px;
    }

    .form-group input {
        width: 100%;
        padding: 12px 16px;
        border: 1.5px solid #e5e7eb;
        border-radius: 10px;
        font-size: 15px;
        font-weight: 300;
        transition: all 0.3s ease;
        box-sizing: border-box;
    }

    .form-group input:focus {
        outline: none;
        border-color: #22863a;
        box-shadow: 0 0 0 3px rgba(34, 134, 58, 0.1);
    }

    .form-group input::placeholder {
        color: #9ca3af;
    }

    .form-group input[readonly] {
        background: #f3f4f6;
        color: #6b7280;
    }

    .password-input-wrapper {
        position: relative;
    }

    .password-toggle {
        position: absolute;
        right: 16px;
        top: 50%;
        transform: translateY(-50%);
        background: none;
        border: none;
        color: #9ca3af;
        cursor: pointer;
        padding: 4px;
    }

    .btn-submit {
        width: 100%;
        padding: 14px;
        background: linear-gradient(135deg, #10b981 0%, #059669 100%);
        color: white;
        border: none;
        border-radius: 10px;
        font-size: 16px;
        font-weight: 300;
        cursor: pointer;
        transition: all 0.3s ease;
    }

    .btn-submit:hover {
        background: linear-gradient(135deg, #059669 0%, #047857 100%);
        transform: translateY(-2px);
        box-shadow: 0 8px 20px rgba(16, 185, 129, 0.3);
    }

    .back-link {
        text-align: center;
        margin-top: 24px;
        font-size: 14px;
        font-weight: 300;
        color: #6b7280;
    }

    .back-link a {
        color: #22863a;
        text-decoration: none;
        font-weight: 400;
    }

    .back-link a:hover {
        text-decoration: underline;
    }

    .back-home-btn {
        display: block;
        text-align: center;
        margin-top: 16px;
        padding: 12px;
        color: #6b7280;
        text-decoration: none;
        border: 1.5px solid #e5e7eb;
        border-radius: 10px;
        font-size: 14px;
        font-weight: 300;
        transition: all 0.3s ease;
    }

    .back-home-btn:hover {
        background: #f9fafb;
        border-color: #d1d5db;
        color: #374151;
    }

    .text-danger {
        color: #ef4444;
        font-size: 13px;
        margin-top: 4px;
        display: block;
    }

    .alert {
        padding: 12px 16px;
        border-radius: 10px;
        margin-bottom: 20px;
        font-size: 14px;
    }

    .alert-success {
        background: #d1fae5;
        color: #065f46;
        border: 1px solid #a7f3d0;
    }

    .alert-danger {
        background: #fee2e2;
        color: #dc2626;
        border: 1px solid #fecaca;
    }

    .info-box {
        background: #f0fdf4;
        border: 1px solid #bbf7d0;
        border-radius: 10px;
        padding: 16px;
        margin-bottom: 24px;
    }

    .info-box p {
        margin: 0;
        font-size: 14px;
        color: #166534;
        display: flex;
        align-items: center;
        gap: 8px;
    }

    .info-box i {
        font-size: 18px;
    }

    .info-box.warning {
        background: #fef3c7;
        border: 1px solid #fcd34d;
    }

    .info-box.warning p {
        color: #92400e;
    }

    .step-indicator {
        display: flex;
        justify-content: center;
        align-items: center;
        gap: 16px;
        margin-bottom: 32px;
    }

    .step {
        display: flex;
        align-items: center;
        gap: 8px;
    }

    .step-number {
        width: 32px;
        height: 32px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 14px;
        font-weight: 500;
    }

    .step-number.active {
        background: #22863a;
        color: white;
    }

    .step-number.completed {
        background: #22863a;
        color: white;
    }

    .step-number.inactive {
        background: #e5e7eb;
        color: #9ca3af;
    }

    .step-label {
        font-size: 13px;
        color: #6b7280;
    }

    .step-label.active {
        color: #22863a;
        font-weight: 500;
    }

    .step-connector {
        width: 40px;
        height: 2px;
        background: #22863a;
    }

    .password-requirements {
        margin-top: 8px;
        padding: 12px;
        background: #f9fafb;
        border-radius: 8px;
        font-size: 12px;
        color: #6b7280;
    }

    .password-requirements ul {
        margin: 0;
        padding-left: 16px;
    }

    .password-requirements li {
        margin-bottom: 4px;
    }

    @@media (max-width: 768px) {
        .reset-card {
            padding: 32px 24px;
        }
        .step-connector {
            width: 20px;
        }
    }
</style>

<div class="reset-container">
    <div class="reset-card">
        <!-- Brand Header -->
        <div class="brand-header">
            <img src="~/images/logo.png" alt="ServConnect Logo" class="brand-logo" />
            <h1 class="brand-name">ServConnect</h1>
        </div>

        <!-- Step Indicator -->
        <div class="step-indicator">
            <div class="step">
                <div class="step-number completed"><i class="bi bi-check"></i></div>
                <span class="step-label">Email</span>
            </div>
            <div class="step-connector"></div>
            <div class="step">
                <div class="step-number completed"><i class="bi bi-check"></i></div>
                <span class="step-label">Verify OTP</span>
            </div>
            <div class="step-connector"></div>
            <div class="step">
                <div class="step-number active">3</div>
                <span class="step-label active">New Password</span>
            </div>
        </div>

        <!-- Title -->
        <h2 class="reset-title">Create New Password</h2>
        <p class="reset-subtitle">Your identity has been verified. Set your new password.</p>

        @* Success Message *@
        @{ var successMsg = TempData["SuccessMessage"] as string; }
        @if (!string.IsNullOrWhiteSpace(successMsg))
        {
            <div class="alert alert-success">
                <i class="bi bi-check-circle"></i> @successMsg
            </div>
        }

        <!-- Warning Info Box -->
        <div class="info-box warning">
            <p><i class="bi bi-clock-history"></i> Session expires in 15 minutes. Complete quickly.</p>
        </div>

        <!-- Form -->
        <form asp-action="ResetPassword" method="post">
            @Html.AntiForgeryToken()
            <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

            <!-- Hidden fields -->
            <input type="hidden" asp-for="Email" />
            <input type="hidden" asp-for="VerificationToken" />

            <div class="form-group">
                <label asp-for="NewPassword">New Password</label>
                <div class="password-input-wrapper">
                    <input asp-for="NewPassword" type="password" id="newPassword" placeholder="••••••••" />
                    <button type="button" class="password-toggle" onclick="togglePassword('newPassword')">
                        <i class="bi bi-eye" id="newPassword-icon"></i>
                    </button>
                </div>
                <span asp-validation-for="NewPassword" class="text-danger"></span>
                <div class="password-requirements">
                    <ul>
                        <li>At least 8 characters long</li>
                        <li>Maximum 40 characters</li>
                    </ul>
                </div>
            </div>

            <div class="form-group">
                <label asp-for="ConfirmPassword">Confirm New Password</label>
                <div class="password-input-wrapper">
                    <input asp-for="ConfirmPassword" type="password" id="confirmPassword" placeholder="••••••••" />
                    <button type="button" class="password-toggle" onclick="togglePassword('confirmPassword')">
                        <i class="bi bi-eye" id="confirmPassword-icon"></i>
                    </button>
                </div>
                <span asp-validation-for="ConfirmPassword" class="text-danger"></span>
            </div>

            <button type="submit" class="btn-submit">
                <i class="bi bi-shield-check"></i> Reset Password
            </button>
        </form>

        <!-- Session Expired Link -->
        <div class="back-link">
            Session expired? <a asp-controller="Account" asp-action="ForgotPassword">Start over</a>
        </div>

        <!-- Back to Login -->
        <a asp-controller="Account" asp-action="Login" class="back-home-btn">
            <i class="bi bi-arrow-left"></i> Back to Login
        </a>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
    
    <script>
        // Password toggle functionality
        function togglePassword(inputId) {
            const input = document.getElementById(inputId);
            const icon = document.getElementById(inputId + '-icon');
            if (input.type === 'password') {
                input.type = 'text';
                icon.classList.remove('bi-eye');
                icon.classList.add('bi-eye-slash');
            } else {
                input.type = 'password';
                icon.classList.remove('bi-eye-slash');
                icon.classList.add('bi-eye');
            }
        }

        // Auto-focus first password input
        document.addEventListener('DOMContentLoaded', function() {
            document.getElementById('newPassword').focus();
        });
    </script>
}