@using ServConnect.ViewModels;
@model ForgotPasswordViewModel;

@{
    ViewData["Title"] = "Forgot Password";
    Layout = "~/Views/Shared/_AccountLayout.cshtml";
}

<style>
    html, body {
        margin: 0;
        padding: 0;
        height: 100%;
        overflow-x: hidden;
    }

    body {
        background: url('/images/login_register_bg.png') center/cover no-repeat;
        font-family: 'Avenir', sans-serif;
    }

    .forgot-container {
        display: flex;
        justify-content: center;
        align-items: center;
        min-height: 100vh;
        padding: 2rem;
        overflow-y: auto;
        box-sizing: border-box;
    }

    .forgot-card {
        background: rgba(255, 255, 255, 0.55);
        border-radius: 20px;
        box-shadow: 0 10px 40px rgba(0, 0, 0, 0.1);
        max-width: 440px;
        width: 100%;
        padding: 48px;
        margin: 20px 0;
        backdrop-filter: blur(5px);
    }

    .brand-header {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 12px;
        margin-bottom: 32px;
    }

    .brand-logo {
        width: 48px;
        height: 48px;
        object-fit: contain;
    }

    .brand-name {
        font-family: 'Fraunces', serif;
        font-size: 24px;
        font-weight: 300;
        color: #1a1a1a;
        margin: 0;
    }

    .forgot-title {
        font-family: 'Fraunces', serif;
        font-size: 28px;
        font-weight: 300;
        color: #1a1a1a;
        text-align: center;
        margin-bottom: 8px;
    }

    .forgot-subtitle {
        text-align: center;
        color: #6b7280;
        font-size: 15px;
        margin-bottom: 32px;
        font-weight: 300;
    }

    .form-group {
        margin-bottom: 20px;
    }

    .form-group label {
        display: block;
        font-size: 14px;
        font-weight: 300;
        color: #374151;
        margin-bottom: 8px;
    }

    .form-group input {
        width: 100%;
        padding: 12px 16px;
        border: 1.5px solid #e5e7eb;
        border-radius: 10px;
        font-size: 15px;
        font-weight: 300;
        transition: all 0.3s ease;
        box-sizing: border-box;
    }

    .form-group input:focus {
        outline: none;
        border-color: #22863a;
        box-shadow: 0 0 0 3px rgba(34, 134, 58, 0.1);
    }

    .form-group input::placeholder {
        color: #9ca3af;
    }

    .btn-submit {
        width: 100%;
        padding: 14px;
        background: linear-gradient(135deg, #10b981 0%, #059669 100%);
        color: white;
        border: none;
        border-radius: 10px;
        font-size: 16px;
        font-weight: 300;
        cursor: pointer;
        transition: all 0.3s ease;
    }

    .btn-submit:hover {
        background: linear-gradient(135deg, #059669 0%, #047857 100%);
        transform: translateY(-2px);
        box-shadow: 0 8px 20px rgba(16, 185, 129, 0.3);
    }

    .back-link {
        text-align: center;
        margin-top: 24px;
        font-size: 14px;
        font-weight: 300;
        color: #6b7280;
    }

    .back-link a {
        color: #22863a;
        text-decoration: none;
        font-weight: 400;
    }

    .back-link a:hover {
        text-decoration: underline;
    }

    .back-home-btn {
        display: block;
        text-align: center;
        margin-top: 16px;
        padding: 12px;
        color: #6b7280;
        text-decoration: none;
        border: 1.5px solid #e5e7eb;
        border-radius: 10px;
        font-size: 14px;
        font-weight: 300;
        transition: all 0.3s ease;
    }

    .back-home-btn:hover {
        background: #f9fafb;
        border-color: #d1d5db;
        color: #374151;
    }

    .text-danger {
        color: #ef4444;
        font-size: 13px;
        margin-top: 4px;
        display: block;
    }

    .alert {
        padding: 12px 16px;
        border-radius: 10px;
        margin-bottom: 20px;
        font-size: 14px;
    }

    .alert-danger {
        background: #fee2e2;
        color: #dc2626;
        border: 1px solid #fecaca;
    }

    .info-box {
        background: #f0fdf4;
        border: 1px solid #bbf7d0;
        border-radius: 10px;
        padding: 16px;
        margin-bottom: 24px;
    }

    .info-box p {
        margin: 0;
        font-size: 14px;
        color: #166534;
        display: flex;
        align-items: center;
        gap: 8px;
    }

    .info-box i {
        font-size: 18px;
    }

    @@media (max-width: 768px) {
        .forgot-card {
            padding: 32px 24px;
        }
    }
</style>

<div class="forgot-container">
    <div class="forgot-card">
        <!-- Brand Header -->
        <div class="brand-header">
            <img src="~/images/logo.png" alt="ServConnect Logo" class="brand-logo" />
            <h1 class="brand-name">ServConnect</h1>
        </div>

        <!-- Title -->
        <h2 class="forgot-title">Forgot Password?</h2>
        <p class="forgot-subtitle">Enter your email address to receive a verification code</p>

        @* Error Message from redirect *@
        @{ var errorMsg = TempData["ErrorMessage"] as string; }
        @if (!string.IsNullOrWhiteSpace(errorMsg))
        {
            <div class="alert alert-danger">
                <i class="bi bi-exclamation-circle"></i> @errorMsg
            </div>
        }

        <!-- Info Box -->
        <div class="info-box">
            <p><i class="bi bi-envelope-check"></i> We'll send a 6-digit OTP to your email</p>
        </div>

        <!-- Form -->
        <form asp-action="ForgotPassword" method="post">
            @Html.AntiForgeryToken()
            <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

            <div class="form-group">
                <label asp-for="Email">Email Address</label>
                <input asp-for="Email" placeholder="you@example.com" />
                <span asp-validation-for="Email" class="text-danger"></span>
            </div>

            <button type="submit" class="btn-submit">
                <i class="bi bi-send"></i> Send OTP
            </button>
        </form>

        <!-- Back to Login Link -->
        <div class="back-link">
            Remember your password? <a asp-controller="Account" asp-action="Login">Sign in</a>
        </div>

        <!-- Back to Home -->
        <a asp-controller="Home" asp-action="Index" class="back-home-btn">
            <i class="bi bi-arrow-left"></i> Back to Home
        </a>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}