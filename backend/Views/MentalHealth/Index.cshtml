@{
    ViewData["Title"] = "Mental Health & Wellbeing - ServConnect";
    var activePlan = ViewBag.ActivePlan as ServConnect.Models.WellnessPlan;
    var recentAssessments = ViewBag.RecentAssessments as List<ServConnect.Models.DepressionAssessment> ?? new List<ServConnect.Models.DepressionAssessment>();
    var recentMoods = ViewBag.RecentMoods as List<ServConnect.Models.MoodEntry> ?? new List<ServConnect.Models.MoodEntry>();
}

<style>
    :root {
        --primary: #8B5CF6;
        --primary-light: #A78BFA;
        --primary-dark: #7C3AED;
        --secondary: #10B981;
        --accent: #F59E0B;
        --danger: #EF4444;
        --text-primary: #1F2937;
        --text-secondary: #6B7280;
        --bg-light: #F3F4F6;
        --card-bg: #FFFFFF;
        --gradient-primary: linear-gradient(135deg, #8B5CF6 0%, #6366F1 100%);
        --gradient-calm: linear-gradient(135deg, #A78BFA 0%, #60A5FA 100%);
    }

    .mental-health-container {
        max-width: 100%;
        margin: 0 auto;
        padding: 20px 8px;
    }

    /* Hero Section */
    .hero-section {
        background: var(--gradient-calm);
        border-radius: 18px;
        padding: 30px 20px;
        margin-bottom: 25px;
        position: relative;
        overflow: hidden;
        color: white;
    }

    .hero-section::before {
        content: '';
        position: absolute;
        top: -50%;
        right: -20%;
        width: 60%;
        height: 200%;
        background: radial-gradient(circle, rgba(255,255,255,0.1) 0%, transparent 60%);
        pointer-events: none;
    }

    .hero-content {
        position: relative;
        z-index: 1;
    }

    .hero-title {
        font-size: 2.5rem;
        font-weight: 800;
        margin-bottom: 16px;
    }

    .hero-subtitle {
        font-size: 1.1rem;
        opacity: 0.9;
        max-width: 600px;
        line-height: 1.7;
        margin-bottom: 30px;
    }

    .hero-actions {
        display: flex;
        gap: 16px;
        flex-wrap: wrap;
    }

    .btn-hero {
        padding: 14px 28px;
        border-radius: 12px;
        font-weight: 600;
        font-size: 1rem;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        gap: 10px;
        transition: all 0.3s ease;
    }

    .btn-hero-primary {
        background: white;
        color: var(--primary);
    }

    .btn-hero-primary:hover {
        background: #F3F4F6;
        transform: translateY(-2px);
        box-shadow: 0 8px 20px rgba(0,0,0,0.2);
    }

    .btn-hero-secondary {
        background: rgba(255,255,255,0.2);
        color: white;
        border: 2px solid rgba(255,255,255,0.3);
    }

    .btn-hero-secondary:hover {
        background: rgba(255,255,255,0.3);
        color: white;
    }

    /* Stats Cards */
    .stats-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
        gap: 20px;
        margin-bottom: 40px;
    }

    .stat-card {
        background: var(--card-bg);
        border-radius: 16px;
        padding: 24px;
        box-shadow: 0 4px 15px rgba(0,0,0,0.05);
        text-align: center;
        transition: all 0.3s ease;
    }

    .stat-card:hover {
        transform: translateY(-4px);
        box-shadow: 0 8px 25px rgba(0,0,0,0.1);
    }

    .stat-icon {
        width: 50px;
        height: 50px;
        border-radius: 14px;
        display: flex;
        align-items: center;
        justify-content: center;
        margin: 0 auto 16px;
        font-size: 1.4rem;
    }

    .stat-value {
        font-size: 1.8rem;
        font-weight: 700;
        color: var(--text-primary);
        margin-bottom: 4px;
    }

    .stat-label {
        font-size: 0.9rem;
        color: var(--text-secondary);
    }

    /* Active Plan Section */
    .active-plan-section {
        background: linear-gradient(135deg, #10B981 0%, #059669 100%);
        border-radius: 20px;
        padding: 30px;
        margin-bottom: 40px;
        color: white;
    }

    .plan-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 24px;
        flex-wrap: wrap;
        gap: 16px;
    }

    .plan-title {
        font-size: 1.4rem;
        font-weight: 700;
    }

    .progress-container {
        flex: 1;
        max-width: 300px;
        margin: 0 20px;
    }

    .progress-bar-bg {
        height: 10px;
        background: rgba(255,255,255,0.3);
        border-radius: 10px;
        overflow: hidden;
    }

    .progress-bar-fill {
        height: 100%;
        background: white;
        border-radius: 10px;
        transition: width 0.5s ease;
    }

    .progress-text {
        font-size: 0.85rem;
        margin-top: 6px;
        opacity: 0.9;
    }

    .btn-view-plan {
        background: white;
        color: #10B981;
        padding: 12px 24px;
        border-radius: 10px;
        font-weight: 600;
        text-decoration: none;
        transition: all 0.3s ease;
    }

    .btn-view-plan:hover {
        transform: translateY(-2px);
        box-shadow: 0 4px 15px rgba(0,0,0,0.2);
    }

    /* Feature Cards */
    .features-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
        gap: 24px;
        margin-bottom: 40px;
    }

    .feature-card {
        background: var(--card-bg);
        border-radius: 20px;
        padding: 30px;
        box-shadow: 0 4px 15px rgba(0,0,0,0.05);
        transition: all 0.3s ease;
        text-decoration: none;
        color: inherit;
        display: block;
    }

    .feature-card:hover {
        transform: translateY(-6px);
        box-shadow: 0 12px 30px rgba(0,0,0,0.12);
    }

    .feature-icon {
        width: 60px;
        height: 60px;
        border-radius: 16px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.5rem;
        margin-bottom: 20px;
    }

    .feature-title {
        font-size: 1.25rem;
        font-weight: 700;
        color: var(--text-primary);
        margin-bottom: 10px;
    }

    .feature-desc {
        font-size: 0.95rem;
        color: var(--text-secondary);
        line-height: 1.6;
    }

    /* Mood Tracker */
    .mood-section {
        background: var(--card-bg);
        border-radius: 20px;
        padding: 30px;
        box-shadow: 0 4px 15px rgba(0,0,0,0.05);
        margin-bottom: 40px;
    }

    .section-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 24px;
    }

    .section-title {
        font-size: 1.3rem;
        font-weight: 700;
        color: var(--text-primary);
    }

    .mood-grid {
        display: flex;
        justify-content: space-between;
        gap: 12px;
    }

    .mood-btn {
        flex: 1;
        padding: 20px 10px;
        border: 2px solid var(--bg-light);
        border-radius: 14px;
        background: white;
        cursor: pointer;
        transition: all 0.3s ease;
        text-align: center;
    }

    .mood-btn:hover, .mood-btn.active {
        border-color: var(--primary);
        background: #F3F4F6;
    }

    .mood-emoji {
        font-size: 2rem;
        margin-bottom: 8px;
    }

    .mood-label {
        font-size: 0.8rem;
        color: var(--text-secondary);
        font-weight: 500;
    }

    /* Resources Section */
    .resources-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
        gap: 16px;
    }

    .resource-card {
        background: var(--bg-light);
        border-radius: 14px;
        padding: 20px;
        display: flex;
        align-items: center;
        gap: 16px;
        text-decoration: none;
        color: inherit;
        transition: all 0.3s ease;
    }

    .resource-card:hover {
        background: white;
        box-shadow: 0 4px 15px rgba(0,0,0,0.08);
    }

    .resource-icon {
        width: 45px;
        height: 45px;
        border-radius: 12px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.1rem;
    }

    .resource-info h4 {
        font-size: 0.95rem;
        font-weight: 600;
        color: var(--text-primary);
        margin-bottom: 4px;
    }

    .resource-info p {
        font-size: 0.8rem;
        color: var(--text-secondary);
        margin: 0;
    }

    /* Helpline Banner */
    .helpline-banner {
        background: linear-gradient(135deg, #EF4444 0%, #DC2626 100%);
        border-radius: 16px;
        padding: 24px 30px;
        display: flex;
        justify-content: space-between;
        align-items: center;
        color: white;
        flex-wrap: wrap;
        gap: 16px;
    }

    .helpline-info h3 {
        font-size: 1.1rem;
        font-weight: 700;
        margin-bottom: 4px;
    }

    .helpline-info p {
        font-size: 0.9rem;
        opacity: 0.9;
        margin: 0;
    }

    .helpline-number {
        font-size: 1.5rem;
        font-weight: 800;
        display: flex;
        align-items: center;
        gap: 10px;
    }

    .helpline-number a {
        color: white;
        text-decoration: none;
    }

    @@media (max-width: 768px) {
        .hero-title {
            font-size: 1.8rem;
        }

        .mood-grid {
            flex-wrap: wrap;
        }

        .mood-btn {
            min-width: calc(33% - 8px);
        }
    }
</style>

<div class="mental-health-container">
    <!-- Hero Section -->
    <div class="hero-section">
        <div class="hero-content">
            <h1 class="hero-title">
                <i class="fas fa-brain me-2"></i>Mental Health & Wellbeing
            </h1>
            <p class="hero-subtitle">
                Your mental health matters. Take a quick assessment to understand your mental state, 
                and receive personalized wellness activities designed just for you. Start your journey 
                to a healthier, happier mind today.
            </p>
            <div class="hero-actions">
                <a href="@Url.Action("Assessment", "MentalHealth")" class="btn-hero btn-hero-primary">
                    <i class="fas fa-clipboard-check"></i> Take Assessment
                </a>
                <a href="@Url.Action("Resources", "MentalHealth")" class="btn-hero btn-hero-secondary">
                    <i class="fas fa-book-open"></i> View Resources
                </a>
            </div>
        </div>
    </div>

    @if (activePlan != null)
    {
        <!-- Active Wellness Plan -->
        <div class="active-plan-section">
            <div class="plan-header">
                <div class="plan-title">
                    <i class="fas fa-heart-pulse me-2"></i>Your Active Wellness Plan
                </div>
                <div class="progress-container">
                    <div class="progress-bar-bg">
                        <div class="progress-bar-fill" style="width: @activePlan.ProgressPercentage%"></div>
                    </div>
                    <div class="progress-text">
                        @activePlan.CompletedTasks of @activePlan.TotalTasks tasks completed (@activePlan.ProgressPercentage%)
                    </div>
                </div>
                <a href="@Url.Action("WellnessPlan", "MentalHealth", new { id = activePlan.Id })" class="btn-view-plan">
                    <i class="fas fa-arrow-right me-2"></i>Continue Plan
                </a>
            </div>
        </div>
    }

    <!-- Stats -->
    <div class="stats-grid">
        <div class="stat-card">
            <div class="stat-icon" style="background: rgba(139, 92, 246, 0.1); color: var(--primary);">
                <i class="fas fa-clipboard-list"></i>
            </div>
            <div class="stat-value">@recentAssessments.Count</div>
            <div class="stat-label">Assessments Taken</div>
        </div>
        <div class="stat-card">
            <div class="stat-icon" style="background: rgba(16, 185, 129, 0.1); color: #10B981;">
                <i class="fas fa-tasks"></i>
            </div>
            <div class="stat-value">@(activePlan?.CompletedTasks ?? 0)</div>
            <div class="stat-label">Tasks Completed</div>
        </div>
        <div class="stat-card">
            <div class="stat-icon" style="background: rgba(255, 215, 0, 0.1); color: #FFD700;">
                <i class="fas fa-star"></i>
            </div>
            <div class="stat-value">⭐ @(activePlan?.TotalStarsEarned ?? 0)</div>
            <div class="stat-label">Stars Earned</div>
        </div>
        <div class="stat-card">
            <div class="stat-icon" style="background: rgba(245, 158, 11, 0.1); color: #F59E0B;">
                <i class="fas fa-smile"></i>
            </div>
            <div class="stat-value">@recentMoods.Count</div>
            <div class="stat-label">Mood Entries</div>
        </div>
        <div class="stat-card">
            <div class="stat-icon" style="background: rgba(99, 102, 241, 0.1); color: #6366F1;">
                <i class="fas fa-fire"></i>
            </div>
            <div class="stat-value">@(activePlan != null ? (DateTime.UtcNow.Date - activePlan.StartDate.Date).Days : 0)</div>
            <div class="stat-label">Days Active</div>
        </div>
    </div>

    <!-- Feature Cards -->
    <div class="features-grid">
        <a href="@Url.Action("Assessment", "MentalHealth")" class="feature-card">
            <div class="feature-icon" style="background: rgba(139, 92, 246, 0.1); color: var(--primary);">
                <i class="fas fa-brain"></i>
            </div>
            <h3 class="feature-title">Mental Health Assessment</h3>
            <p class="feature-desc">
                Take a quick, confidential assessment to understand your mental wellbeing. 
                AI-powered analysis provides personalized insights.
            </p>
        </a>

        <a href="@Url.Action("WellnessPlan", "MentalHealth")" class="feature-card">
            <div class="feature-icon" style="background: rgba(16, 185, 129, 0.1); color: #10B981;">
                <i class="fas fa-calendar-check"></i>
            </div>
            <h3 class="feature-title">7-Day Wellness Plan</h3>
            <p class="feature-desc">
                Receive a personalized 7-day plan with activities like nature walks, 
                mindfulness exercises, and local place recommendations.
            </p>
        </a>

        <a href="@Url.Action("Rewards", "MentalHealth")" class="feature-card">
            <div class="feature-icon" style="background: rgba(255, 215, 0, 0.1); color: #FFD700;">
                <i class="fas fa-gift"></i>
            </div>
            <h3 class="feature-title">Rewards & Gifts</h3>
            <p class="feature-desc">
                Earn stars by completing wellness tasks and redeem them for amazing rewards 
                like coffee mugs, plants, and books!
            </p>
        </a>

        <a href="@Url.Action("History", "MentalHealth")" class="feature-card">
            <div class="feature-icon" style="background: rgba(245, 158, 11, 0.1); color: #F59E0B;">
                <i class="fas fa-chart-line"></i>
            </div>
            <h3 class="feature-title">Track Progress</h3>
            <p class="feature-desc">
                Monitor your mental health journey over time. View past assessments 
                and see how your wellness improves with each completed activity.
            </p>
        </a>
    </div>

    <!-- Mood Tracker -->
    <div class="mood-section">
        <div class="section-header">
            <h2 class="section-title"><i class="fas fa-smile-beam me-2"></i>How are you feeling today?</h2>
        </div>
        <div class="mood-grid" id="moodGrid">
            <button class="mood-btn" data-mood="1">
                <div class="mood-emoji">😢</div>
                <div class="mood-label">Very Bad</div>
            </button>
            <button class="mood-btn" data-mood="2">
                <div class="mood-emoji">😔</div>
                <div class="mood-label">Bad</div>
            </button>
            <button class="mood-btn" data-mood="3">
                <div class="mood-emoji">😐</div>
                <div class="mood-label">Okay</div>
            </button>
            <button class="mood-btn" data-mood="4">
                <div class="mood-emoji">🙂</div>
                <div class="mood-label">Good</div>
            </button>
            <button class="mood-btn" data-mood="5">
                <div class="mood-emoji">😊</div>
                <div class="mood-label">Great</div>
            </button>
        </div>
    </div>

    <!-- Quick Resources -->
    <div class="mood-section">
        <div class="section-header">
            <h2 class="section-title"><i class="fas fa-book-heart me-2"></i>Quick Resources</h2>
            <a href="@Url.Action("Resources", "MentalHealth")" style="color: var(--primary); text-decoration: none; font-weight: 600;">
                View All <i class="fas fa-arrow-right ms-1"></i>
            </a>
        </div>
        <div class="resources-grid">
            <a href="#" class="resource-card" onclick="showBreathingExercise(); return false;">
                <div class="resource-icon" style="background: rgba(139, 92, 246, 0.1); color: var(--primary);">
                    <i class="fas fa-wind"></i>
                </div>
                <div class="resource-info">
                    <h4>Breathing Exercise</h4>
                    <p>Calm your mind in 5 minutes</p>
                </div>
            </a>
            <a href="@Url.Action("Resources", "MentalHealth")#meditation" class="resource-card">
                <div class="resource-icon" style="background: rgba(16, 185, 129, 0.1); color: #10B981;">
                    <i class="fas fa-spa"></i>
                </div>
                <div class="resource-info">
                    <h4>Guided Meditation</h4>
                    <p>Relaxation techniques</p>
                </div>
            </a>
            <a href="@Url.Action("Resources", "MentalHealth")#helplines" class="resource-card">
                <div class="resource-icon" style="background: rgba(245, 158, 11, 0.1); color: #F59E0B;">
                    <i class="fas fa-phone"></i>
                </div>
                <div class="resource-info">
                    <h4>Helpline Numbers</h4>
                    <p>24/7 support available</p>
                </div>
            </a>
            <a href="@Url.Action("Resources", "MentalHealth")#articles" class="resource-card">
                <div class="resource-icon" style="background: rgba(99, 102, 241, 0.1); color: #6366F1;">
                    <i class="fas fa-newspaper"></i>
                </div>
                <div class="resource-info">
                    <h4>Self-Help Articles</h4>
                    <p>Tips & strategies</p>
                </div>
            </a>
        </div>
    </div>

    <!-- Emergency Helpline -->
    <div class="helpline-banner">
        <div class="helpline-info">
            <h3><i class="fas fa-life-ring me-2"></i>Need immediate help?</h3>
            <p>If you're in crisis, please reach out. Help is available 24/7.</p>
        </div>
        <div class="helpline-number">
            <i class="fas fa-phone-alt"></i>
            <a href="tel:1056">DISHA Kerala: 1056</a>
        </div>
    </div>
</div>

<!-- Breathing Exercise Modal -->
<div class="modal fade" id="breathingModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content" style="border-radius: 20px; border: none;">
            <div class="modal-body text-center p-5">
                <div id="breathingAnimation" style="width: 150px; height: 150px; border-radius: 50%; background: var(--gradient-calm); margin: 0 auto 30px; display: flex; align-items: center; justify-content: center; transition: transform 4s ease-in-out;">
                    <span style="color: white; font-size: 1.2rem; font-weight: 600;" id="breathingText">Breathe In</span>
                </div>
                <h4 class="mb-3">4-7-8 Breathing Exercise</h4>
                <p class="text-muted mb-4">Follow the animation to calm your nervous system</p>
                <button class="btn btn-primary" onclick="startBreathing()">Start Exercise</button>
                <button class="btn btn-outline-secondary ms-2" data-bs-dismiss="modal">Close</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // Mood logging
        document.querySelectorAll('.mood-btn').forEach(btn => {
            btn.addEventListener('click', function() {
                const mood = this.dataset.mood;
                document.querySelectorAll('.mood-btn').forEach(b => b.classList.remove('active'));
                this.classList.add('active');

                fetch('/MentalHealth/LogMood', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                        'RequestVerificationToken': document.querySelector('input[name="__RequestVerificationToken"]')?.value || ''
                    },
                    body: JSON.stringify({ mood: parseInt(mood) })
                })
                .then(res => res.json())
                .then(data => {
                    if (data.success) {
                        showToast('Mood logged successfully!', 'success');
                    }
                })
                .catch(err => console.error('Error logging mood:', err));
            });
        });

        // Breathing exercise
        function showBreathingExercise() {
            var modal = new bootstrap.Modal(document.getElementById('breathingModal'));
            modal.show();
        }

        let breathingInterval;
        function startBreathing() {
            const animation = document.getElementById('breathingAnimation');
            const text = document.getElementById('breathingText');
            let phase = 0;
            const phases = [
                { text: 'Breathe In', scale: 1.3, duration: 4000 },
                { text: 'Hold', scale: 1.3, duration: 7000 },
                { text: 'Breathe Out', scale: 1, duration: 8000 }
            ];

            if (breathingInterval) clearInterval(breathingInterval);

            function nextPhase() {
                const current = phases[phase % 3];
                text.textContent = current.text;
                animation.style.transform = `scale(${current.scale})`;
                phase++;
            }

            nextPhase();
            breathingInterval = setInterval(nextPhase, phases[phase % 3]?.duration || 4000);
        }

        function showToast(message, type) {
            // Create toast notification
            const toast = document.createElement('div');
            toast.className = `alert alert-${type === 'success' ? 'success' : 'danger'} position-fixed`;
            toast.style.cssText = 'top: 20px; right: 20px; z-index: 9999; animation: fadeIn 0.3s;';
            toast.innerHTML = `<i class="fas fa-${type === 'success' ? 'check-circle' : 'exclamation-circle'} me-2"></i>${message}`;
            document.body.appendChild(toast);
            setTimeout(() => toast.remove(), 3000);
        }
    </script>
}
