@model ServConnect.Models.DepressionAssessment
@{
    ViewData["Title"] = "Assessment Results - ServConnect";
}

<style>
    :root {
        --primary: #8B5CF6;
        --secondary: #10B981;
        --danger: #EF4444;
        --accent: #F59E0B;
        --text-primary: #1F2937;
        --text-secondary: #6B7280;
    }

    .results-container {
        max-width: 100%;
        margin: 0 auto;
        padding: 15px 8px 60px;
    }

    .results-card {
        background: white;
        border-radius: 24px;
        padding: 40px;
        box-shadow: 0 10px 40px rgba(0,0,0,0.1);
        text-align: center;
    }

    .result-icon {
        font-size: 5rem;
        margin-bottom: 24px;
    }

    .result-title {
        font-size: 2rem;
        font-weight: 800;
        margin-bottom: 16px;
    }

    .result-title.positive {
        color: var(--secondary);
    }

    .result-title.concern {
        color: var(--accent);
    }

    .result-description {
        font-size: 1.1rem;
        color: var(--text-secondary);
        margin-bottom: 30px;
        line-height: 1.7;
    }

    .score-card {
        background: linear-gradient(135deg, #D1FAE5 0%, #A7F3D0 100%);
        border-radius: 16px;
        padding: 24px;
        margin-bottom: 30px;
    }

    .score-card.concern {
        background: linear-gradient(135deg, #FEF3C7 0%, #FDE68A 100%);
    }

    .score-label {
        font-size: 0.9rem;
        color: var(--text-secondary);
        margin-bottom: 8px;
    }

    .score-value {
        font-size: 3rem;
        font-weight: 800;
        color: var(--secondary);
    }

    .score-card.concern .score-value {
        color: #92400E;
    }

    .tips-section {
        text-align: left;
        margin-top: 30px;
        padding-top: 30px;
        border-top: 1px solid #E5E7EB;
    }

    .tips-title {
        font-size: 1.2rem;
        font-weight: 700;
        color: var(--text-primary);
        margin-bottom: 20px;
        display: flex;
        align-items: center;
        gap: 10px;
    }

    .tips-list {
        list-style: none;
        padding: 0;
        margin: 0;
    }

    .tips-list li {
        padding: 12px 0;
        display: flex;
        align-items: flex-start;
        gap: 12px;
        border-bottom: 1px solid #F3F4F6;
    }

    .tips-list li:last-child {
        border-bottom: none;
    }

    .tips-list li i {
        color: var(--secondary);
        margin-top: 4px;
    }

    .action-buttons {
        display: flex;
        gap: 16px;
        justify-content: center;
        margin-top: 30px;
        flex-wrap: wrap;
    }

    .btn-action {
        padding: 14px 28px;
        border-radius: 12px;
        font-weight: 600;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        gap: 8px;
        transition: all 0.3s ease;
    }

    .btn-primary-custom {
        background: var(--primary);
        color: white;
    }

    .btn-primary-custom:hover {
        background: #7C3AED;
        transform: translateY(-2px);
        color: white;
    }

    .btn-secondary-custom {
        background: #F3F4F6;
        color: var(--text-primary);
    }

    .btn-secondary-custom:hover {
        background: #E5E7EB;
    }

    .assessment-details {
        margin-top: 30px;
        padding: 20px;
        background: #F9FAFB;
        border-radius: 14px;
        text-align: left;
    }

    .detail-row {
        display: flex;
        justify-content: space-between;
        padding: 8px 0;
        border-bottom: 1px solid #E5E7EB;
    }

    .detail-row:last-child {
        border-bottom: none;
    }

    .detail-label {
        color: var(--text-secondary);
        font-size: 0.9rem;
    }

    .detail-value {
        font-weight: 600;
        color: var(--text-primary);
    }
</style>

<div class="results-container">
    <div class="results-card">
        @if (!Model.IsDepressed)
        {
            <div class="result-icon">🌟</div>
            <h1 class="result-title positive">Great News!</h1>
            <p class="result-description">
                Based on your responses, your mental health appears to be in a good state. 
                Keep maintaining your healthy habits and continue taking care of yourself!
            </p>

            <div class="score-card">
                <div class="score-label">Mental Wellness Score</div>
                <div class="score-value">@((100 - Model.DepressionProbability * 100).ToString("0"))%</div>
            </div>

            <div class="tips-section">
                <h3 class="tips-title">
                    <i class="fas fa-lightbulb" style="color: var(--accent);"></i>
                    Tips to Maintain Your Wellbeing
                </h3>
                <ul class="tips-list">
                    <li>
                        <i class="fas fa-check-circle"></i>
                        <span>Continue maintaining your healthy sleep schedule and nutrition habits</span>
                    </li>
                    <li>
                        <i class="fas fa-check-circle"></i>
                        <span>Stay connected with friends and family - social bonds are crucial for mental health</span>
                    </li>
                    <li>
                        <i class="fas fa-check-circle"></i>
                        <span>Practice regular exercise and mindfulness activities</span>
                    </li>
                    <li>
                        <i class="fas fa-check-circle"></i>
                        <span>Take breaks from work/study to prevent burnout</span>
                    </li>
                    <li>
                        <i class="fas fa-check-circle"></i>
                        <span>Consider periodic mental health check-ins to maintain awareness</span>
                    </li>
                </ul>
            </div>
        }
        else
        {
            <div class="result-icon">💪</div>
            <h1 class="result-title concern">We're Here For You</h1>
            <p class="result-description">
                Your responses indicate that you may benefit from some extra support. 
                Remember, this is common and help is available. We've prepared a personalized 
                wellness plan to help you feel better.
            </p>

            <div class="score-card concern">
                <div class="score-label">Severity Level</div>
                <div class="score-value" style="font-size: 2rem; text-transform: capitalize;">@Model.SeverityLevel</div>
            </div>

            @if (!string.IsNullOrEmpty(Model.WellnessPlanId))
            {
                <div class="action-buttons">
                    <a href="@Url.Action("WellnessPlan", "MentalHealth", new { id = Model.WellnessPlanId })" class="btn-action btn-primary-custom">
                        <i class="fas fa-heart-pulse"></i> View Your Wellness Plan
                    </a>
                </div>
            }
        }

        <div class="assessment-details">
            <h4 style="margin-bottom: 16px; color: var(--text-primary);">Assessment Summary</h4>
            <div class="detail-row">
                <span class="detail-label">Assessment Date</span>
                <span class="detail-value">@Model.AssessmentDate.ToString("MMMM dd, yyyy")</span>
            </div>
            <div class="detail-row">
                <span class="detail-label">Confidence Level</span>
                <span class="detail-value">@((Model.Confidence * 100).ToString("0"))%</span>
            </div>
            <div class="detail-row">
                <span class="detail-label">User Type</span>
                <span class="detail-value">@(Model.IsStudent ? "Student" : "Working Professional")</span>
            </div>
            <div class="detail-row">
                <span class="detail-label">Age</span>
                <span class="detail-value">@Model.Age years</span>
            </div>
        </div>

        <div class="action-buttons">
            <a href="@Url.Action("Index", "MentalHealth")" class="btn-action btn-secondary-custom">
                <i class="fas fa-home"></i> Back to Mental Health
            </a>
            <a href="@Url.Action("Assessment", "MentalHealth")" class="btn-action btn-primary-custom">
                <i class="fas fa-redo"></i> Take Again
            </a>
        </div>
    </div>
</div>
