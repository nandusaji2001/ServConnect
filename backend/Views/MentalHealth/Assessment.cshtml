@{
    ViewData["Title"] = "Mental Health Assessment - ServConnect";
    var userName = ViewBag.UserName as string ?? "User";
    var userAge = ViewBag.UserAge ?? 25;
    var userGender = ViewBag.UserGender ?? "Male";
}

<style>
    :root {
        --primary: #8B5CF6;
        --primary-light: #A78BFA;
        --primary-dark: #7C3AED;
        --secondary: #10B981;
        --accent: #F59E0B;
        --danger: #EF4444;
        --text-primary: #1F2937;
        --text-secondary: #6B7280;
        --bg-light: #F3F4F6;
        --card-bg: #FFFFFF;
    }

    .assessment-container {
        max-width: 100%;
        margin: 0 auto;
        padding: 15px 8px;
    }

    .assessment-header {
        text-align: center;
        margin-bottom: 40px;
    }

    .assessment-header h1 {
        font-size: 2rem;
        font-weight: 800;
        color: var(--text-primary);
        margin-bottom: 12px;
    }

    .assessment-header p {
        color: var(--text-secondary);
        font-size: 1.05rem;
    }

    .progress-steps {
        display: flex;
        justify-content: center;
        gap: 8px;
        margin-bottom: 40px;
    }

    .step {
        width: 12px;
        height: 12px;
        border-radius: 50%;
        background: #E5E7EB;
        transition: all 0.3s ease;
    }

    .step.active {
        background: var(--primary);
        transform: scale(1.2);
    }

    .step.completed {
        background: var(--secondary);
    }

    .assessment-card {
        background: var(--card-bg);
        border-radius: 24px;
        padding: 40px;
        box-shadow: 0 10px 40px rgba(0,0,0,0.08);
    }

    .step-content {
        display: none;
    }

    .step-content.active {
        display: block;
        animation: fadeIn 0.4s ease;
    }

    @@keyframes fadeIn {
        from { opacity: 0; transform: translateY(10px); }
        to { opacity: 1; transform: translateY(0); }
    }

    .step-title {
        font-size: 1.5rem;
        font-weight: 700;
        color: var(--text-primary);
        margin-bottom: 8px;
        display: flex;
        align-items: center;
        gap: 12px;
    }

    .step-title i {
        color: var(--primary);
    }

    .step-subtitle {
        color: var(--text-secondary);
        margin-bottom: 30px;
    }

    .form-group {
        margin-bottom: 24px;
    }

    .form-label {
        font-weight: 600;
        color: var(--text-primary);
        margin-bottom: 10px;
        display: block;
    }

    .form-label .required {
        color: var(--danger);
    }

    .form-select, .form-control {
        padding: 14px 18px;
        border-radius: 12px;
        border: 2px solid #E5E7EB;
        font-size: 1rem;
        transition: all 0.3s ease;
        width: 100%;
    }

    .form-select:focus, .form-control:focus {
        border-color: var(--primary);
        box-shadow: 0 0 0 4px rgba(139, 92, 246, 0.1);
        outline: none;
    }

    .rating-scale {
        display: flex;
        gap: 10px;
        flex-wrap: wrap;
    }

    .rating-btn {
        flex: 1;
        min-width: 60px;
        padding: 16px 10px;
        border: 2px solid #E5E7EB;
        border-radius: 12px;
        background: white;
        cursor: pointer;
        transition: all 0.3s ease;
        text-align: center;
    }

    .rating-btn:hover {
        border-color: var(--primary);
        background: rgba(139, 92, 246, 0.05);
    }

    .rating-btn.selected {
        border-color: var(--primary);
        background: var(--primary);
        color: white;
    }

    .rating-value {
        font-size: 1.2rem;
        font-weight: 700;
    }

    .rating-label {
        font-size: 0.75rem;
        margin-top: 4px;
    }

    .yes-no-btns {
        display: flex;
        gap: 16px;
    }

    .yes-no-btn {
        flex: 1;
        padding: 20px;
        border: 2px solid #E5E7EB;
        border-radius: 14px;
        background: white;
        cursor: pointer;
        transition: all 0.3s ease;
        text-align: center;
        font-weight: 600;
        font-size: 1.1rem;
    }

    .yes-no-btn:hover {
        border-color: var(--primary);
    }

    .yes-no-btn.selected {
        border-color: var(--primary);
        background: var(--primary);
        color: white;
    }

    .btn-navigation {
        display: flex;
        justify-content: space-between;
        margin-top: 40px;
        gap: 16px;
    }

    .btn-nav {
        padding: 14px 28px;
        border-radius: 12px;
        font-weight: 600;
        font-size: 1rem;
        cursor: pointer;
        transition: all 0.3s ease;
        display: flex;
        align-items: center;
        gap: 8px;
        border: none;
    }

    .btn-prev {
        background: #E5E7EB;
        color: var(--text-primary);
    }

    .btn-prev:hover {
        background: #D1D5DB;
    }

    .btn-next, .btn-submit {
        background: var(--primary);
        color: white;
    }

    .btn-next:hover, .btn-submit:hover {
        background: var(--primary-dark);
        transform: translateY(-2px);
    }

    .btn-submit {
        background: var(--secondary);
    }

    .btn-submit:hover {
        background: #059669;
    }

    .student-fields, .working-fields {
        display: none;
    }

    .student-fields.active, .working-fields.active {
        display: block;
    }

    .info-box {
        background: rgba(139, 92, 246, 0.1);
        border-radius: 12px;
        padding: 16px;
        margin-bottom: 24px;
        display: flex;
        gap: 12px;
        align-items: flex-start;
    }

    .info-box i {
        color: var(--primary);
        font-size: 1.2rem;
        margin-top: 2px;
    }

    .info-box p {
        margin: 0;
        color: var(--text-secondary);
        font-size: 0.9rem;
        line-height: 1.5;
    }

    .location-status {
        padding: 12px 16px;
        border-radius: 10px;
        background: #FEF3C7;
        color: #92400E;
        font-size: 0.9rem;
        display: flex;
        align-items: center;
        gap: 10px;
        margin-top: 10px;
    }

    .location-status.success {
        background: #D1FAE5;
        color: #065F46;
    }

    /* Loading overlay */
    .loading-overlay {
        display: none;
        position: fixed;
        top: 0;
        left: 0;
        right: 0;
        bottom: 0;
        background: rgba(255,255,255,0.9);
        z-index: 9999;
        justify-content: center;
        align-items: center;
        flex-direction: column;
    }

    .loading-overlay.active {
        display: flex;
    }

    .loading-spinner {
        width: 60px;
        height: 60px;
        border: 4px solid #E5E7EB;
        border-top-color: var(--primary);
        border-radius: 50%;
        animation: spin 1s linear infinite;
        margin-bottom: 20px;
    }

    @@keyframes spin {
        to { transform: rotate(360deg); }
    }

    .loading-text {
        font-size: 1.1rem;
        color: var(--text-primary);
        font-weight: 600;
    }

    @@media (max-width: 600px) {
        .assessment-card {
            padding: 24px;
        }

        .rating-scale {
            gap: 6px;
        }

        .rating-btn {
            min-width: 50px;
            padding: 12px 6px;
        }
    }
</style>

<div class="assessment-container">
    <div class="assessment-header">
        <h1><i class="fas fa-brain me-2" style="color: var(--primary);"></i>Mental Health Assessment</h1>
        <p>Answer a few questions to understand your mental wellbeing better</p>
    </div>

    <div class="progress-steps">
        <div class="step active" data-step="1"></div>
        <div class="step" data-step="2"></div>
        <div class="step" data-step="3"></div>
        <div class="step" data-step="4"></div>
    </div>

    <div class="assessment-card">
        <form id="assessmentForm">
            @Html.AntiForgeryToken()

            <!-- Step 1: Basic Info -->
            <div class="step-content active" data-step="1">
                <h2 class="step-title"><i class="fas fa-user"></i>Basic Information</h2>
                <p class="step-subtitle">Let's start with some basic details about you</p>

                <div class="row">
                    <div class="col-md-6">
                        <div class="form-group">
                            <label class="form-label">Gender <span class="required">*</span></label>
                            <select class="form-select" name="Gender" id="gender" required>
                                <option value="">Select Gender</option>
                                @if (userGender == "Male")
                                {
                                    <option value="Male" selected>Male</option>
                                    <option value="Female">Female</option>
                                }
                                else
                                {
                                    <option value="Male">Male</option>
                                    <option value="Female" selected>Female</option>
                                }
                            </select>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="form-group">
                            <label class="form-label">Age <span class="required">*</span></label>
                            <input type="number" class="form-control" name="Age" id="age" value="@userAge" min="10" max="100" required>
                        </div>
                    </div>
                </div>

                <div class="form-group">
                    <label class="form-label">Are you a Student or Working Professional? <span class="required">*</span></label>
                    <div class="yes-no-btns">
                        <button type="button" class="yes-no-btn" data-value="true" onclick="selectUserType(this, true)">
                            <i class="fas fa-graduation-cap me-2"></i>Student
                        </button>
                        <button type="button" class="yes-no-btn" data-value="false" onclick="selectUserType(this, false)">
                            <i class="fas fa-briefcase me-2"></i>Working Professional
                        </button>
                    </div>
                    <input type="hidden" name="IsStudent" id="isStudent" required>
                </div>

                <div class="info-box">
                    <i class="fas fa-info-circle"></i>
                    <p>Your responses are completely confidential and will only be used to provide personalized recommendations.</p>
                </div>
            </div>

            <!-- Step 2: Lifestyle Factors -->
            <div class="step-content" data-step="2">
                <h2 class="step-title"><i class="fas fa-moon"></i>Lifestyle Factors</h2>
                <p class="step-subtitle">Tell us about your daily habits</p>

                <div class="form-group">
                    <label class="form-label">How many hours do you typically sleep? <span class="required">*</span></label>
                    <select class="form-select" name="SleepDuration" id="sleepDuration" required>
                        <option value="">Select Sleep Duration</option>
                        <option value="Less than 5 hours">Less than 5 hours</option>
                        <option value="5-6 hours">5-6 hours</option>
                        <option value="7-8 hours">7-8 hours</option>
                        <option value="More than 8 hours">More than 8 hours</option>
                    </select>
                </div>

                <div class="form-group">
                    <label class="form-label">How would you describe your dietary habits? <span class="required">*</span></label>
                    <select class="form-select" name="DietaryHabits" id="dietaryHabits" required>
                        <option value="">Select Dietary Habits</option>
                        <option value="Healthy">Healthy (Regular, balanced meals)</option>
                        <option value="Moderate">Moderate (Occasionally unhealthy)</option>
                        <option value="Unhealthy">Unhealthy (Irregular, junk food)</option>
                    </select>
                </div>

                <div class="form-group">
                    <label class="form-label">How many hours do you work/study per day? <span class="required">*</span></label>
                    <select class="form-select" name="WorkStudyHours" id="workStudyHours" required>
                        <option value="">Select Hours</option>
                        @for (int i = 0; i <= 12; i++)
                        {
                            <option value="@i">@i hours</option>
                        }
                    </select>
                </div>

                <div class="form-group">
                    <label class="form-label">Rate your financial stress level (1 = None, 5 = Extreme) <span class="required">*</span></label>
                    <div class="rating-scale">
                        @for (int i = 1; i <= 5; i++)
                        {
                            var label = i switch { 1 => "None", 2 => "Mild", 3 => "Moderate", 4 => "High", 5 => "Extreme", _ => "" };
                            <button type="button" class="rating-btn" data-field="financialStress" data-value="@i" onclick="selectRating(this)">
                                <div class="rating-value">@i</div>
                                <div class="rating-label">@label</div>
                            </button>
                        }
                    </div>
                    <input type="hidden" name="FinancialStress" id="financialStress" required>
                </div>
            </div>

            <!-- Step 3: Work/Study Specific -->
            <div class="step-content" data-step="3">
                <h2 class="step-title"><i class="fas fa-clipboard-list"></i>Work/Study Details</h2>
                <p class="step-subtitle">Share details about your current situation</p>

                <!-- Student Fields -->
                <div class="student-fields" id="studentFields">
                    <div class="form-group">
                        <label class="form-label">Rate your academic pressure (1 = Low, 5 = Very High)</label>
                        <div class="rating-scale">
                            @for (int i = 1; i <= 5; i++)
                            {
                                var label = i switch { 1 => "Low", 2 => "Mild", 3 => "Moderate", 4 => "High", 5 => "Very High", _ => "" };
                                <button type="button" class="rating-btn" data-field="academicPressure" data-value="@i" onclick="selectRating(this)">
                                    <div class="rating-value">@i</div>
                                    <div class="rating-label">@label</div>
                                </button>
                            }
                        </div>
                        <input type="hidden" name="AcademicPressure" id="academicPressure">
                    </div>

                    <div class="form-group">
                        <label class="form-label">Your CGPA/GPA (0-10 scale)</label>
                        <input type="number" class="form-control" name="CGPA" id="cgpa" step="0.1" min="0" max="10" placeholder="e.g., 7.5">
                    </div>

                    <div class="form-group">
                        <label class="form-label">Rate your study satisfaction (1 = Very Dissatisfied, 5 = Very Satisfied)</label>
                        <div class="rating-scale">
                            @for (int i = 1; i <= 5; i++)
                            {
                                var label = i switch { 1 => "Very Low", 2 => "Low", 3 => "Moderate", 4 => "High", 5 => "Very High", _ => "" };
                                <button type="button" class="rating-btn" data-field="studySatisfaction" data-value="@i" onclick="selectRating(this)">
                                    <div class="rating-value">@i</div>
                                    <div class="rating-label">@label</div>
                                </button>
                            }
                        </div>
                        <input type="hidden" name="StudySatisfaction" id="studySatisfaction">
                    </div>
                </div>

                <!-- Working Professional Fields -->
                <div class="working-fields" id="workingFields">
                    <div class="form-group">
                        <label class="form-label">Rate your work pressure (1 = Low, 5 = Very High)</label>
                        <div class="rating-scale">
                            @for (int i = 1; i <= 5; i++)
                            {
                                var label = i switch { 1 => "Low", 2 => "Mild", 3 => "Moderate", 4 => "High", 5 => "Very High", _ => "" };
                                <button type="button" class="rating-btn" data-field="workPressure" data-value="@i" onclick="selectRating(this)">
                                    <div class="rating-value">@i</div>
                                    <div class="rating-label">@label</div>
                                </button>
                            }
                        </div>
                        <input type="hidden" name="WorkPressure" id="workPressure">
                    </div>

                    <div class="form-group">
                        <label class="form-label">Rate your job satisfaction (1 = Very Dissatisfied, 5 = Very Satisfied)</label>
                        <div class="rating-scale">
                            @for (int i = 1; i <= 5; i++)
                            {
                                var label = i switch { 1 => "Very Low", 2 => "Low", 3 => "Moderate", 4 => "High", 5 => "Very High", _ => "" };
                                <button type="button" class="rating-btn" data-field="jobSatisfaction" data-value="@i" onclick="selectRating(this)">
                                    <div class="rating-value">@i</div>
                                    <div class="rating-label">@label</div>
                                </button>
                            }
                        </div>
                        <input type="hidden" name="JobSatisfaction" id="jobSatisfaction">
                    </div>
                </div>

                <div class="info-box">
                    <i class="fas fa-lightbulb"></i>
                    <p>Being honest about your work/study situation helps us provide better recommendations for managing stress.</p>
                </div>
            </div>

            <!-- Step 4: Mental Health History -->
            <div class="step-content" data-step="4">
                <h2 class="step-title"><i class="fas fa-heart"></i>Mental Health Factors</h2>
                <p class="step-subtitle">These questions help us understand your situation better</p>

                <div class="form-group">
                    <label class="form-label">Does anyone in your family have a history of mental illness? <span class="required">*</span></label>
                    <div class="yes-no-btns">
                        <button type="button" class="yes-no-btn" onclick="selectYesNo(this, 'familyHistoryMentalIllness', true)">
                            <i class="fas fa-check me-2"></i>Yes
                        </button>
                        <button type="button" class="yes-no-btn" onclick="selectYesNo(this, 'familyHistoryMentalIllness', false)">
                            <i class="fas fa-times me-2"></i>No
                        </button>
                    </div>
                    <input type="hidden" name="FamilyHistoryMentalIllness" id="familyHistoryMentalIllness" required>
                </div>

                <div class="form-group">
                    <label class="form-label">Have you ever had suicidal thoughts? <span class="required">*</span></label>
                    <div class="yes-no-btns">
                        <button type="button" class="yes-no-btn" onclick="selectYesNo(this, 'suicidalThoughts', true)">
                            <i class="fas fa-check me-2"></i>Yes
                        </button>
                        <button type="button" class="yes-no-btn" onclick="selectYesNo(this, 'suicidalThoughts', false)">
                            <i class="fas fa-times me-2"></i>No
                        </button>
                    </div>
                    <input type="hidden" name="SuicidalThoughts" id="suicidalThoughts" required>
                </div>

                <div class="form-group">
                    <label class="form-label">Enable Location for Nearby Recommendations</label>
                    <button type="button" class="btn btn-outline-primary" id="locationBtn" onclick="getLocation()">
                        <i class="fas fa-map-marker-alt me-2"></i>Enable Location
                    </button>
                    <div class="location-status" id="locationStatus" style="display: none;">
                        <i class="fas fa-spinner fa-spin"></i>
                        <span>Fetching location...</span>
                    </div>
                    <input type="hidden" name="Latitude" id="latitude">
                    <input type="hidden" name="Longitude" id="longitude">
                    <input type="hidden" name="City" id="city">
                </div>

                <div class="info-box" style="background: rgba(239, 68, 68, 0.1);">
                    <i class="fas fa-exclamation-triangle" style="color: var(--danger);"></i>
                    <p><strong>Important:</strong> If you're currently in crisis or having thoughts of self-harm, please reach out to a helpline immediately. 
                    <a href="tel:1056" style="color: var(--danger); font-weight: 600;">DISHA Kerala: 1056</a> or 
                    <a href="tel:04712552056" style="color: var(--danger); font-weight: 600;">0471-2552056</a></p>
                </div>
            </div>

            <div class="btn-navigation">
                <button type="button" class="btn-nav btn-prev" id="prevBtn" onclick="prevStep()" style="display: none;">
                    <i class="fas fa-arrow-left"></i> Previous
                </button>
                <button type="button" class="btn-nav btn-next" id="nextBtn" onclick="nextStep()">
                    Next <i class="fas fa-arrow-right"></i>
                </button>
                <button type="submit" class="btn-nav btn-submit" id="submitBtn" style="display: none;">
                    <i class="fas fa-check-circle"></i> Get Assessment
                </button>
            </div>
        </form>
    </div>
</div>

<!-- Loading Overlay -->
<div class="loading-overlay" id="loadingOverlay">
    <div class="loading-spinner"></div>
    <div class="loading-text">Analyzing your responses...</div>
</div>

@section Scripts {
    <script>
        let currentStep = 1;
        const totalSteps = 4;
        let isStudent = null;

        function selectUserType(btn, isStudentValue) {
            document.querySelectorAll('.form-group .yes-no-btn').forEach(b => b.classList.remove('selected'));
            btn.classList.add('selected');
            document.getElementById('isStudent').value = isStudentValue;
            isStudent = isStudentValue;

            // Show/hide relevant fields
            if (isStudentValue) {
                document.getElementById('studentFields').classList.add('active');
                document.getElementById('workingFields').classList.remove('active');
            } else {
                document.getElementById('studentFields').classList.remove('active');
                document.getElementById('workingFields').classList.add('active');
            }
        }

        function selectRating(btn) {
            const field = btn.dataset.field;
            const value = btn.dataset.value;

            // Remove selected from siblings
            btn.parentElement.querySelectorAll('.rating-btn').forEach(b => b.classList.remove('selected'));
            btn.classList.add('selected');

            document.getElementById(field).value = value;
        }

        function selectYesNo(btn, field, value) {
            const container = btn.parentElement;
            container.querySelectorAll('.yes-no-btn').forEach(b => b.classList.remove('selected'));
            btn.classList.add('selected');
            document.getElementById(field).value = value;
        }

        function validateStep(step) {
            const stepContent = document.querySelector(`.step-content[data-step="${step}"]`);
            const requiredFields = stepContent.querySelectorAll('[required]');
            let isValid = true;

            requiredFields.forEach(field => {
                if (!field.value || field.value === '') {
                    isValid = false;
                    field.classList.add('is-invalid');
                } else {
                    field.classList.remove('is-invalid');
                }
            });

            // Custom validations
            if (step === 1 && isStudent === null) {
                alert('Please select if you are a Student or Working Professional');
                return false;
            }

            if (step === 2 && !document.getElementById('financialStress').value) {
                alert('Please rate your financial stress level');
                return false;
            }

            if (step === 4) {
                if (!document.getElementById('familyHistoryMentalIllness').value) {
                    alert('Please answer the family history question');
                    return false;
                }
                if (!document.getElementById('suicidalThoughts').value) {
                    alert('Please answer the suicidal thoughts question');
                    return false;
                }
            }

            return isValid;
        }

        function nextStep() {
            if (!validateStep(currentStep)) return;

            if (currentStep < totalSteps) {
                document.querySelector(`.step-content[data-step="${currentStep}"]`).classList.remove('active');
                document.querySelector(`.step[data-step="${currentStep}"]`).classList.remove('active');
                document.querySelector(`.step[data-step="${currentStep}"]`).classList.add('completed');

                currentStep++;

                document.querySelector(`.step-content[data-step="${currentStep}"]`).classList.add('active');
                document.querySelector(`.step[data-step="${currentStep}"]`).classList.add('active');

                updateButtons();
            }
        }

        function prevStep() {
            if (currentStep > 1) {
                document.querySelector(`.step-content[data-step="${currentStep}"]`).classList.remove('active');
                document.querySelector(`.step[data-step="${currentStep}"]`).classList.remove('active');

                currentStep--;

                document.querySelector(`.step-content[data-step="${currentStep}"]`).classList.add('active');
                document.querySelector(`.step[data-step="${currentStep}"]`).classList.add('active');
                document.querySelector(`.step[data-step="${currentStep}"]`).classList.remove('completed');

                updateButtons();
            }
        }

        function updateButtons() {
            document.getElementById('prevBtn').style.display = currentStep > 1 ? 'flex' : 'none';
            document.getElementById('nextBtn').style.display = currentStep < totalSteps ? 'flex' : 'none';
            document.getElementById('submitBtn').style.display = currentStep === totalSteps ? 'flex' : 'none';
        }

        function getLocation() {
            const statusDiv = document.getElementById('locationStatus');
            const btn = document.getElementById('locationBtn');

            if (!navigator.geolocation) {
                statusDiv.innerHTML = '<i class="fas fa-times-circle"></i><span>Geolocation not supported</span>';
                statusDiv.style.display = 'flex';
                return;
            }

            btn.disabled = true;
            statusDiv.style.display = 'flex';
            statusDiv.innerHTML = '<i class="fas fa-spinner fa-spin"></i><span>Fetching location...</span>';

            navigator.geolocation.getCurrentPosition(
                (position) => {
                    document.getElementById('latitude').value = position.coords.latitude;
                    document.getElementById('longitude').value = position.coords.longitude;

                    statusDiv.classList.add('success');
                    statusDiv.innerHTML = '<i class="fas fa-check-circle"></i><span>Location captured successfully!</span>';
                    btn.textContent = 'Location Enabled';
                    btn.disabled = true;

                    // Try to get city name (reverse geocoding)
                    fetch(`https://nominatim.openstreetmap.org/reverse?lat=${position.coords.latitude}&lon=${position.coords.longitude}&format=json`)
                        .then(res => res.json())
                        .then(data => {
                            if (data.address) {
                                const city = data.address.city || data.address.town || data.address.village || data.address.county;
                                document.getElementById('city').value = city || '';
                                statusDiv.innerHTML = `<i class="fas fa-check-circle"></i><span>Location: ${city || 'Captured'}</span>`;
                            }
                        })
                        .catch(() => {});
                },
                (error) => {
                    statusDiv.classList.remove('success');
                    statusDiv.innerHTML = `<i class="fas fa-exclamation-triangle"></i><span>Could not get location. Recommendations will be general.</span>`;
                    btn.disabled = false;
                },
                { enableHighAccuracy: true, timeout: 10000 }
            );
        }

        // Form submission
        document.getElementById('assessmentForm').addEventListener('submit', async function(e) {
            e.preventDefault();

            if (!validateStep(currentStep)) return;

            const formData = new FormData(this);
            const data = {};
            formData.forEach((value, key) => {
                if (value === 'true') data[key] = true;
                else if (value === 'false') data[key] = false;
                else if (!isNaN(value) && value !== '') data[key] = parseFloat(value);
                else data[key] = value;
            });

            // Show loading
            document.getElementById('loadingOverlay').classList.add('active');

            try {
                const response = await fetch('/MentalHealth/Assessment', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/x-www-form-urlencoded',
                    },
                    body: new URLSearchParams(formData)
                });

                const result = await response.json();

                if (result.success) {
                    if (result.isDepressed && result.wellnessPlanId) {
                        window.location.href = `/MentalHealth/WellnessPlan?id=${result.wellnessPlanId}`;
                    } else {
                        window.location.href = `/MentalHealth/Results/${result.assessmentId}`;
                    }
                } else {
                    alert(result.message || 'An error occurred. Please try again.');
                    document.getElementById('loadingOverlay').classList.remove('active');
                }
            } catch (error) {
                console.error('Error:', error);
                alert('An error occurred. Please try again.');
                document.getElementById('loadingOverlay').classList.remove('active');
            }
        });
    </script>
}
