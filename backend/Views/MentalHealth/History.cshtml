@model List<ServConnect.Models.DepressionAssessment>
@{
    ViewData["Title"] = "Assessment History - ServConnect";
}

<style>
    :root {
        --primary: #8B5CF6;
        --secondary: #10B981;
        --danger: #EF4444;
        --accent: #F59E0B;
        --text-primary: #1F2937;
        --text-secondary: #6B7280;
    }

    .history-container {
        max-width: 100%;
        margin: 0 auto;
        padding: 15px 8px 60px;
    }

    .history-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 40px;
        flex-wrap: wrap;
        gap: 16px;
    }

    .history-header h1 {
        font-size: 2rem;
        font-weight: 800;
        color: var(--text-primary);
    }

    .btn-new-assessment {
        padding: 12px 24px;
        background: var(--primary);
        color: white;
        border: none;
        border-radius: 12px;
        font-weight: 600;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        gap: 8px;
        transition: all 0.3s ease;
    }

    .btn-new-assessment:hover {
        background: #7C3AED;
        transform: translateY(-2px);
        color: white;
    }

    .assessment-list {
        display: flex;
        flex-direction: column;
        gap: 16px;
    }

    .assessment-item {
        background: white;
        border-radius: 16px;
        padding: 24px;
        box-shadow: 0 4px 15px rgba(0,0,0,0.05);
        display: flex;
        gap: 20px;
        transition: all 0.3s ease;
    }

    .assessment-item:hover {
        transform: translateY(-4px);
        box-shadow: 0 12px 30px rgba(0,0,0,0.1);
    }

    .assessment-status {
        width: 60px;
        height: 60px;
        border-radius: 16px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.5rem;
        flex-shrink: 0;
    }

    .status-good {
        background: #D1FAE5;
        color: var(--secondary);
    }

    .status-concern {
        background: #FEF3C7;
        color: var(--accent);
    }

    .assessment-content {
        flex: 1;
    }

    .assessment-date {
        font-size: 0.85rem;
        color: var(--text-secondary);
        margin-bottom: 6px;
    }

    .assessment-result {
        font-size: 1.15rem;
        font-weight: 700;
        color: var(--text-primary);
        margin-bottom: 8px;
    }

    .assessment-details {
        display: flex;
        gap: 20px;
        font-size: 0.9rem;
        color: var(--text-secondary);
        flex-wrap: wrap;
    }

    .assessment-details span {
        display: flex;
        align-items: center;
        gap: 6px;
    }

    .assessment-actions {
        display: flex;
        flex-direction: column;
        gap: 8px;
        justify-content: center;
    }

    .btn-view {
        padding: 10px 20px;
        background: #F3F4F6;
        color: var(--text-primary);
        border: none;
        border-radius: 10px;
        font-weight: 600;
        text-decoration: none;
        font-size: 0.9rem;
        transition: all 0.3s ease;
        display: inline-flex;
        align-items: center;
        gap: 6px;
    }

    .btn-view:hover {
        background: var(--primary);
        color: white;
    }

    .empty-state {
        text-align: center;
        padding: 60px 20px;
        background: white;
        border-radius: 20px;
        box-shadow: 0 4px 15px rgba(0,0,0,0.05);
    }

    .empty-icon {
        font-size: 4rem;
        margin-bottom: 20px;
    }

    .empty-title {
        font-size: 1.5rem;
        font-weight: 700;
        color: var(--text-primary);
        margin-bottom: 12px;
    }

    .empty-desc {
        color: var(--text-secondary);
        margin-bottom: 24px;
    }

    .back-btn {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        color: var(--text-secondary);
        text-decoration: none;
        font-weight: 500;
        margin-bottom: 30px;
        transition: color 0.3s ease;
    }

    .back-btn:hover {
        color: var(--primary);
    }

    @@media (max-width: 600px) {
        .assessment-item {
            flex-direction: column;
        }

        .assessment-actions {
            flex-direction: row;
        }
    }
</style>

<div class="history-container">
    <a href="@Url.Action("Index", "MentalHealth")" class="back-btn">
        <i class="fas fa-arrow-left"></i> Back to Mental Health
    </a>

    <div class="history-header">
        <h1><i class="fas fa-history me-2" style="color: var(--primary);"></i>Assessment History</h1>
        <a href="@Url.Action("Assessment", "MentalHealth")" class="btn-new-assessment">
            <i class="fas fa-plus"></i> New Assessment
        </a>
    </div>

    @if (Model.Count == 0)
    {
        <div class="empty-state">
            <div class="empty-icon">📋</div>
            <h2 class="empty-title">No Assessments Yet</h2>
            <p class="empty-desc">Take your first mental health assessment to understand your wellbeing better.</p>
            <a href="@Url.Action("Assessment", "MentalHealth")" class="btn-new-assessment">
                <i class="fas fa-clipboard-check me-2"></i> Take Assessment
            </a>
        </div>
    }
    else
    {
        <div class="assessment-list">
            @foreach (var assessment in Model)
            {
                <div class="assessment-item">
                    <div class="assessment-status @(assessment.IsDepressed ? "status-concern" : "status-good")">
                        <i class="fas @(assessment.IsDepressed ? "fa-exclamation-circle" : "fa-check-circle")"></i>
                    </div>
                    <div class="assessment-content">
                        <div class="assessment-date">
                            <i class="far fa-calendar me-1"></i>
                            @assessment.AssessmentDate.ToString("MMMM dd, yyyy 'at' h:mm tt")
                        </div>
                        <div class="assessment-result">
                            @if (assessment.IsDepressed)
                            {
                                <span style="color: var(--accent);">
                                    Signs of Depression Detected 
                                    <span style="font-weight: normal; font-size: 0.9rem;">
                                        (@assessment.SeverityLevel level)
                                    </span>
                                </span>
                            }
                            else
                            {
                                <span style="color: var(--secondary);">Healthy Mental State</span>
                            }
                        </div>
                        <div class="assessment-details">
                            <span>
                                <i class="fas fa-user"></i>
                                @(assessment.IsStudent ? "Student" : "Professional")
                            </span>
                            <span>
                                <i class="fas fa-birthday-cake"></i>
                                Age @assessment.Age
                            </span>
                            <span>
                                <i class="fas fa-chart-line"></i>
                                Confidence: @((assessment.Confidence * 100).ToString("0"))%
                            </span>
                            @if (assessment.IsDepressed && !string.IsNullOrEmpty(assessment.WellnessPlanId))
                            {
                                <span style="color: var(--secondary);">
                                    <i class="fas fa-heart-pulse"></i>
                                    Wellness Plan Created
                                </span>
                            }
                        </div>
                    </div>
                    <div class="assessment-actions">
                        <a href="@Url.Action("Results", "MentalHealth", new { id = assessment.Id })" class="btn-view">
                            <i class="fas fa-eye"></i> View Details
                        </a>
                        @if (assessment.IsDepressed && !string.IsNullOrEmpty(assessment.WellnessPlanId))
                        {
                            <a href="@Url.Action("WellnessPlan", "MentalHealth", new { id = assessment.WellnessPlanId })" class="btn-view" style="background: var(--secondary); color: white;">
                                <i class="fas fa-heart-pulse"></i> View Plan
                            </a>
                        }
                    </div>
                </div>
            }
        </div>
    }
</div>
