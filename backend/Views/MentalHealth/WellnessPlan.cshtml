@section Scripts {
    <script>
        const planId = '@Model.Id';
        let currentTaskId = null;
        let selectedPlace = null;
        let selectedRating = 0;
        let userLat = null;
        let userLng = null;
        let currentGameDay = 1;
        
        // Game state stored in localStorage
        const gameStateKey = 'wellnessGames_' + planId;
        let gameState = JSON.parse(localStorage.getItem(gameStateKey)) || {};

        // Initialize game state display
        function updateGameDisplay() {
            for (let day = 1; day <= 7; day++) {
                const dayGames = gameState[day] || [];
                const count = dayGames.length;
                const countEl = document.getElementById('gamesCount-' + day);
                if (countEl) countEl.textContent = count;
                
                // Mark completed games
                ['breathing', 'memory', 'gratitude', 'word'].forEach(game => {
                    const gameCard = document.getElementById('game-' + game + '-' + day);
                    if (gameCard && dayGames.includes(game)) {
                        gameCard.classList.add('game-completed');
                    }
                });
            }
        }
        updateGameDisplay();

        // Get user location and auto-load places
        if (navigator.geolocation) {
            navigator.geolocation.getCurrentPosition(
                pos => {
                    userLat = pos.coords.latitude;
                    userLng = pos.coords.longitude;
                    // Auto-load places for place tasks without suggestions
                    autoLoadAllPlaces();
                },
                err => {
                    console.log('Location not available');
                    // Show location required message in auto-places sections
                    document.querySelectorAll('.auto-places-section').forEach(section => {
                        section.innerHTML = `
                            <div class="auto-places-loading">
                                <i class="fas fa-map-marker-alt me-2"></i> Enable location to see nearby places
                            </div>
                        `;
                    });
                }
            );
        }

        // Auto-load places for all place tasks without suggestions
        async function autoLoadAllPlaces() {
            const placeSections = document.querySelectorAll('.auto-places-section');
            for (const section of placeSections) {
                const taskId = section.dataset.taskId;
                const placeType = section.dataset.placeType;
                await autoLoadPlaces(taskId, placeType);
            }
        }

        async function autoLoadPlaces(taskId, placeType) {
            const section = document.getElementById('autoPlaces-' + taskId);
            if (!section || !userLat || !userLng) return;

            try {
                const response = await fetch(`/MentalHealth/GetNearbyPlaces?latitude=${userLat}&longitude=${userLng}&placeType=${placeType}`);
                const data = await response.json();

                if (!data.success || !data.places || data.places.length === 0) {
                    section.innerHTML = `
                        <div class="auto-places-loading">
                            <i class="fas fa-map-marker-alt me-2"></i> No places found nearby
                        </div>
                    `;
                    return;
                }

                // Sort by rating (highest first) and get top 3
                const sortedPlaces = data.places
                    .filter(p => p.rating !== null && p.rating !== undefined)
                    .sort((a, b) => (b.rating || 0) - (a.rating || 0));
                const top3 = sortedPlaces.slice(0, 3);
                
                if (top3.length === 0) {
                    section.innerHTML = `
                        <div class="auto-places-loading">
                            <i class="fas fa-map-marker-alt me-2"></i> No rated places found nearby
                        </div>
                    `;
                    return;
                }
                
                section.innerHTML = `
                    <div class="auto-places-grid">
                        ${top3.map((place, idx) => `
                            <div class="auto-place-card" data-place='${JSON.stringify(place).replace(/'/g, "&#39;")}'>
                                <div class="place-img-container">
                                    ${place.photoUrl ? 
                                        `<img src="${place.photoUrl}" alt="${place.name}">` :
                                        `<i class="fas fa-map-marker-alt"></i>`
                                    }
                                </div>
                                <div class="place-info">
                                    <div class="place-name" title="${place.name}">${place.name}</div>
                                    <div class="place-meta">
                                        ${place.distance ? `<span><i class="fas fa-location-dot"></i> ${place.distance}</span>` : ''}
                                        ${place.isOpen !== null ? 
                                            `<span style="color: ${place.isOpen ? '#10B981' : '#EF4444'};">${place.isOpen ? '● Open' : '● Closed'}</span>` : ''
                                        }
                                    </div>
                                    <button class="select-btn" onclick="event.stopPropagation(); selectAutoPlace('${taskId}', this.closest('.auto-place-card'))">
                                        <i class="fas fa-check me-1"></i> Choose
                                    </button>
                                </div>
                            </div>
                        `).join('')}
                    </div>
                `;
            } catch (error) {
                console.error('Error auto-loading places:', error);
                section.innerHTML = `
                    <div class="auto-places-loading">
                        <i class="fas fa-exclamation-circle me-2"></i> Error loading places
                    </div>
                `;
            }
        }

        async function selectAutoPlace(taskId, cardElement) {
            const place = JSON.parse(cardElement.dataset.place.replace(/&#39;/g, "'"));
            
            try {
                const response = await fetch('/MentalHealth/SavePlaceSuggestion', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json'
                    },
                    body: JSON.stringify({
                        planId: planId,
                        taskId: taskId,
                        place: place
                    })
                });

                const data = await response.json();

                if (data.success) {
                    showToast('Place selected! Refreshing...', 'success');
                    setTimeout(() => location.reload(), 500);
                } else {
                    showToast('Error saving place. Please try again.', 'danger');
                }
            } catch (error) {
                console.error('Error:', error);
                showToast('Error saving place. Please try again.', 'danger');
            }
        }

        function showDay(dayNum) {
            // Hide all days
            document.querySelectorAll('.day-content').forEach(el => el.style.display = 'none');
            // Show selected day
            document.getElementById('day-' + dayNum).style.display = 'block';
            // Update tabs
            document.querySelectorAll('.day-tab').forEach(tab => {
                tab.classList.remove('active');
                if (tab.dataset.day == dayNum) {
                    tab.classList.add('active');
                }
            });
        }

        function showLockedMessage(dayNum) {
            showToast(`Day ${dayNum} is locked! Complete the current day's tasks first. 🔒`, 'info');
        }

        function changePlace(taskId, placeType) {
            // Reuse findPlaces functionality to change the selected place
            findPlaces(taskId, placeType);
        }

        function findPlaces(taskId, placeType) {
            currentTaskId = taskId;
            const modal = new bootstrap.Modal(document.getElementById('placesModal'));
            modal.show();

            const placesList = document.getElementById('placesList');
            placesList.innerHTML = `
                <div class="text-center py-4">
                    <i class="fas fa-spinner fa-spin fa-2x mb-3" style="color: var(--primary);"></i>
                    <p>Finding nearby places...</p>
                </div>
            `;

            if (!userLat || !userLng) {
                // Try to get location again
                if (navigator.geolocation) {
                    navigator.geolocation.getCurrentPosition(
                        pos => {
                            userLat = pos.coords.latitude;
                            userLng = pos.coords.longitude;
                            fetchPlaces(placeType);
                        },
                        err => {
                            placesList.innerHTML = `
                                <div class="text-center py-4">
                                    <i class="fas fa-map-marker-alt fa-2x mb-3" style="color: var(--danger);"></i>
                                    <p>Please enable location to find nearby places.</p>
                                    <button class="btn btn-primary" onclick="requestLocation('${placeType}')">
                                        <i class="fas fa-location-arrow me-1"></i> Enable Location
                                    </button>
                                </div>
                            `;
                        }
                    );
                }
            } else {
                fetchPlaces(placeType);
            }
        }

        function requestLocation(placeType) {
            navigator.geolocation.getCurrentPosition(
                pos => {
                    userLat = pos.coords.latitude;
                    userLng = pos.coords.longitude;
                    fetchPlaces(placeType);
                },
                err => {
                    alert('Unable to get your location. Please enable location services.');
                }
            );
        }

        async function fetchPlaces(placeType) {
            try {
                const response = await fetch(`/MentalHealth/GetNearbyPlaces?latitude=${userLat}&longitude=${userLng}&placeType=${placeType}`);
                const data = await response.json();

                const placesList = document.getElementById('placesList');

                if (!data.success || !data.places || data.places.length === 0) {
                    placesList.innerHTML = `
                        <div class="text-center py-4">
                            <i class="fas fa-search fa-2x mb-3" style="color: var(--accent);"></i>
                            <p>No nearby places found. Try a different type or location.</p>
                        </div>
                    `;
                    return;
                }

                placesList.innerHTML = data.places.map(place => `
                    <div class="place-option" data-place='${JSON.stringify(place)}' onclick="selectPlaceOption(this)">
                        <div style="display: flex; gap: 16px; align-items: center;">
                            ${place.photoUrl ? 
                                `<img src="${place.photoUrl}" style="width: 70px; height: 70px; border-radius: 10px; object-fit: cover;">` :
                                `<div style="width: 70px; height: 70px; border-radius: 10px; background: #E5E7EB; display: flex; align-items: center; justify-content: center;">
                                    <i class="fas fa-map-marker-alt" style="font-size: 1.2rem; color: #9CA3AF;"></i>
                                </div>`
                            }
                            <div style="flex: 1;">
                                <div style="font-weight: 700; margin-bottom: 4px;">${place.name}</div>
                                <div style="font-size: 0.85rem; color: var(--text-secondary); margin-bottom: 6px;">${place.address}</div>
                                <div style="display: flex; gap: 12px; font-size: 0.8rem;">
                                    ${place.rating ? `<span style="color: #F59E0B;"><i class="fas fa-star"></i> ${place.rating.toFixed(1)}</span>` : ''}
                                    ${place.distance ? `<span style="color: var(--text-secondary);"><i class="fas fa-map-marker-alt"></i> ${place.distance}</span>` : ''}
                                    ${place.isOpen !== null ? 
                                        `<span class="place-status ${place.isOpen ? 'open' : 'closed'}">${place.isOpen ? 'Open' : 'Closed'}</span>` : ''
                                    }
                                </div>
                            </div>
                        </div>
                    </div>
                `).join('');

            } catch (error) {
                console.error('Error fetching places:', error);
                document.getElementById('placesList').innerHTML = `
                    <div class="text-center py-4">
                        <i class="fas fa-exclamation-circle fa-2x mb-3" style="color: var(--danger);"></i>
                        <p>Error loading places. Please try again.</p>
                    </div>
                `;
            }
        }

        function selectPlaceOption(element) {
            document.querySelectorAll('.place-option').forEach(el => el.classList.remove('selected'));
            element.classList.add('selected');
            selectedPlace = JSON.parse(element.dataset.place);
            document.getElementById('selectPlaceBtn').disabled = false;
        }

        async function selectPlace() {
            if (!selectedPlace || !currentTaskId) return;

            try {
                const response = await fetch('/MentalHealth/SavePlaceSuggestion', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json'
                    },
                    body: JSON.stringify({
                        planId: planId,
                        taskId: currentTaskId,
                        place: selectedPlace
                    })
                });

                const data = await response.json();

                if (data.success) {
                    // Close modal and refresh page to show the place
                    bootstrap.Modal.getInstance(document.getElementById('placesModal')).hide();
                    location.reload();
                } else {
                    alert('Error saving place. Please try again.');
                }
            } catch (error) {
                console.error('Error:', error);
                alert('Error saving place. Please try again.');
            }
        }

        function completeTask(taskId) {
            currentTaskId = taskId;
            selectedRating = 0;
            document.querySelectorAll('.rating-star').forEach(star => star.classList.remove('active'));
            document.getElementById('taskNotes').value = '';
            
            const modal = new bootstrap.Modal(document.getElementById('completionModal'));
            modal.show();
        }

        // Rating stars interaction
        document.querySelectorAll('.rating-star').forEach(star => {
            star.addEventListener('click', function() {
                selectedRating = parseInt(this.dataset.rating);
                document.querySelectorAll('.rating-star').forEach((s, idx) => {
                    s.classList.toggle('active', idx < selectedRating);
                });
            });

            star.addEventListener('mouseenter', function() {
                const rating = parseInt(this.dataset.rating);
                document.querySelectorAll('.rating-star').forEach((s, idx) => {
                    s.style.color = idx < rating ? '#F59E0B' : '#E5E7EB';
                });
            });
        });

        document.getElementById('ratingStars').addEventListener('mouseleave', function() {
            document.querySelectorAll('.rating-star').forEach((star, idx) => {
                star.style.color = idx < selectedRating ? '#F59E0B' : '#E5E7EB';
            });
        });

        async function submitCompletion() {
            if (!currentTaskId) return;

            const notes = document.getElementById('taskNotes').value;

            try {
                const response = await fetch('/MentalHealth/CompleteTask', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json'
                    },
                    body: JSON.stringify({
                        planId: planId,
                        taskId: currentTaskId,
                        notes: notes,
                        rating: selectedRating || null
                    })
                });

                const data = await response.json();

                if (data.success) {
                    // Update UI
                    const taskCard = document.getElementById('task-' + currentTaskId);
                    taskCard.classList.add('completed');
                    
                    // Check if it's a featured place task or regular task
                    const isFeatured = taskCard.classList.contains('featured-place-task');

                    // Update task actions - handle both regular and featured task cards
                    const actionsDiv = taskCard.querySelector('.task-actions') || taskCard.querySelector('.featured-actions');
                    if (actionsDiv) {
                        if (isFeatured) {
                            // Keep the directions button, update complete button
                            const directionsBtn = actionsDiv.querySelector('.btn-directions-white');
                            const directionsHtml = directionsBtn ? directionsBtn.outerHTML : '';
                            actionsDiv.innerHTML = directionsHtml + `
                                <span class="btn-featured" style="background: rgba(255,255,255,0.3);">
                                    <i class="fas fa-check-circle me-1"></i> Completed!
                                </span>
                            `;
                            taskCard.classList.add('completed-featured');
                        } else {
                            actionsDiv.innerHTML = `
                                <div style="color: var(--secondary); font-weight: 600;">
                                    <i class="fas fa-check-circle me-1"></i> Completed
                                </div>
                            `;
                        }
                    }

                    // Update progress
                    document.getElementById('progressBar').style.width = data.progressPercentage + '%';
                    document.getElementById('progressPercent').textContent = data.progressPercentage + '%';
                    document.getElementById('completedCount').textContent = data.completedTasks;

                    // Close modal
                    bootstrap.Modal.getInstance(document.getElementById('completionModal')).hide();

                    // Show success message
                    showToast('Task completed! Keep up the great work! 🎉', 'success');

                    // Check if all tasks completed
                    if (data.isCompleted) {
                        setTimeout(() => {
                            showCelebration();
                        }, 500);
                    }
                } else {
                    alert(data.message || 'Error completing task. Please try again.');
                }
            } catch (error) {
                console.error('Error:', error);
                alert('Error completing task. Please try again.');
            }
        }

        function showToast(message, type) {
            const toast = document.createElement('div');
            const alertClass = type === 'success' ? 'success' : type === 'info' ? 'info' : 'danger';
            const icon = type === 'success' ? 'check-circle' : type === 'info' ? 'info-circle' : 'exclamation-circle';
            toast.className = `alert alert-${alertClass} position-fixed`;
            toast.style.cssText = 'top: 20px; right: 20px; z-index: 9999; animation: fadeIn 0.3s; max-width: 350px;';
            toast.innerHTML = `<i class="fas fa-${icon} me-2"></i>${message}`;
            document.body.appendChild(toast);
            setTimeout(() => toast.remove(), 4000);
        }

        function showCelebration() {
            const modal = document.createElement('div');
            modal.innerHTML = `
                <div class="modal fade show" style="display: block; background: rgba(0,0,0,0.5);">
                    <div class="modal-dialog modal-dialog-centered">
                        <div class="modal-content" style="border-radius: 24px; text-align: center; padding: 40px;">
                            <div style="font-size: 5rem; margin-bottom: 20px;">🎊</div>
                            <h2 style="color: var(--secondary); margin-bottom: 16px;">Congratulations!</h2>
                            <p style="color: var(--text-secondary); font-size: 1.1rem; margin-bottom: 24px;">
                                You've completed your 7-day wellness journey! We're so proud of you for taking care of your mental health.
                            </p>
                            <a href="/MentalHealth" class="btn btn-success btn-lg">
                                <i class="fas fa-home me-2"></i>Back to Mental Health
                            </a>
                        </div>
                    </div>
                </div>
            `;
            document.body.appendChild(modal);
        }

        // ==================== GAMES ====================
        
        function playGame(gameType, day) {
            currentGameDay = day;
            const dayGames = gameState[day] || [];
            
            if (dayGames.includes(gameType)) {
                showToast('You already completed this game today! Try another one.', 'info');
                return;
            }
            
            switch(gameType) {
                case 'breathing':
                    new bootstrap.Modal(document.getElementById('breathingGameModal')).show();
                    break;
                case 'memory':
                    initMemoryGame();
                    new bootstrap.Modal(document.getElementById('memoryGameModal')).show();
                    break;
                case 'gratitude':
                    document.getElementById('gratitude1').value = '';
                    document.getElementById('gratitude2').value = '';
                    document.getElementById('gratitude3').value = '';
                    new bootstrap.Modal(document.getElementById('gratitudeGameModal')).show();
                    break;
                case 'word':
                    initWordGame();
                    new bootstrap.Modal(document.getElementById('wordGameModal')).show();
                    break;
            }
        }
        
        function completeGame(gameType) {
            if (!gameState[currentGameDay]) gameState[currentGameDay] = [];
            if (!gameState[currentGameDay].includes(gameType)) {
                gameState[currentGameDay].push(gameType);
                localStorage.setItem(gameStateKey, JSON.stringify(gameState));
                updateGameDisplay();
                showToast('Game completed! +' + (gameType === 'memory' || gameType === 'word' ? '15' : '10') + ' points! 🎮', 'success');
            }
        }
        
        // Breathing Game
        let breathingInterval = null;
        let breathCycles = 0;
        
        function startBreathingGame() {
            const circle = document.getElementById('breathingCircle');
            const text = document.getElementById('breathingText');
            const streakDiv = document.getElementById('breathingStreak');
            const btn = document.getElementById('startBreathingBtn');
            
            btn.style.display = 'none';
            streakDiv.style.display = 'inline-flex';
            breathCycles = 0;
            
            const phases = [
                { text: 'Breathe In', scale: 1.4, duration: 4000 },
                { text: 'Hold', scale: 1.4, duration: 4000 },
                { text: 'Breathe Out', scale: 1, duration: 4000 }
            ];
            let phase = 0;
            
            function nextPhase() {
                const current = phases[phase % 3];
                text.textContent = current.text;
                circle.style.transform = `scale(${current.scale})`;
                
                if (phase % 3 === 2) {
                    breathCycles++;
                    document.getElementById('breathStreakCount').textContent = breathCycles;
                    
                    if (breathCycles >= 3) {
                        clearInterval(breathingInterval);
                        text.textContent = 'Done! 🎉';
                        completeGame('breathing');
                        setTimeout(() => {
                            bootstrap.Modal.getInstance(document.getElementById('breathingGameModal')).hide();
                            btn.style.display = 'inline-block';
                            streakDiv.style.display = 'none';
                        }, 1500);
                        return;
                    }
                }
                phase++;
            }
            
            nextPhase();
            breathingInterval = setInterval(nextPhase, 4000);
        }
        
        // Memory Game
        const memoryEmojis = ['🌸', '🌈', '☀️', '🌙', '💫', '🦋', '🌺', '🍀'];
        let memoryCards = [];
        let flippedCards = [];
        let matchedPairs = 0;
        let memoryMoves = 0;
        
        function initMemoryGame() {
            const grid = document.getElementById('memoryGrid');
            const emojis = [...memoryEmojis.slice(0, 4), ...memoryEmojis.slice(0, 4)];
            memoryCards = emojis.sort(() => Math.random() - 0.5);
            flippedCards = [];
            matchedPairs = 0;
            memoryMoves = 0;
            document.getElementById('memoryMoves').textContent = '0';
            document.getElementById('restartMemoryBtn').style.display = 'none';
            
            grid.innerHTML = memoryCards.map((emoji, i) => `
                <div class="memory-card" data-index="${i}" data-emoji="${emoji}" onclick="flipCard(this)">
                    <span style="display: none;">${emoji}</span>
                </div>
            `).join('');
        }
        
        function flipCard(card) {
            if (flippedCards.length >= 2 || card.classList.contains('flipped') || card.classList.contains('matched')) return;
            
            card.classList.add('flipped');
            card.querySelector('span').style.display = 'block';
            flippedCards.push(card);
            
            if (flippedCards.length === 2) {
                memoryMoves++;
                document.getElementById('memoryMoves').textContent = memoryMoves;
                
                const [card1, card2] = flippedCards;
                if (card1.dataset.emoji === card2.dataset.emoji) {
                    card1.classList.add('matched');
                    card2.classList.add('matched');
                    matchedPairs++;
                    flippedCards = [];
                    
                    if (matchedPairs === 4) {
                        setTimeout(() => {
                            completeGame('memory');
                            document.getElementById('restartMemoryBtn').style.display = 'inline-block';
                        }, 500);
                    }
                } else {
                    setTimeout(() => {
                        card1.classList.remove('flipped');
                        card2.classList.remove('flipped');
                        card1.querySelector('span').style.display = 'none';
                        card2.querySelector('span').style.display = 'none';
                        flippedCards = [];
                    }, 800);
                }
            }
        }
        
        // Gratitude Game
        function submitGratitude() {
            const g1 = document.getElementById('gratitude1').value.trim();
            const g2 = document.getElementById('gratitude2').value.trim();
            const g3 = document.getElementById('gratitude3').value.trim();
            
            if (g1 && g2 && g3) {
                completeGame('gratitude');
                bootstrap.Modal.getInstance(document.getElementById('gratitudeGameModal')).hide();
            } else {
                showToast('Please fill in all 3 gratitude entries', 'error');
            }
        }
        
        // Word Puzzle Game
        const positiveWords = ['HAPPY', 'PEACE', 'SMILE', 'LOVE', 'CALM', 'JOY', 'HOPE', 'KIND', 'BRAVE', 'STRONG'];
        let currentWord = '';
        
        function initWordGame() {
            currentWord = positiveWords[Math.floor(Math.random() * positiveWords.length)];
            const scrambled = currentWord.split('').sort(() => Math.random() - 0.5).join('');
            document.getElementById('scrambledWord').textContent = scrambled;
            document.getElementById('wordGuess').value = '';
            document.getElementById('wordResult').style.display = 'none';
        }
        
        function checkWord() {
            const guess = document.getElementById('wordGuess').value.toUpperCase().trim();
            const resultDiv = document.getElementById('wordResult');
            
            if (guess === currentWord) {
                resultDiv.innerHTML = '<span style="color: #10B981; font-weight: 700;"><i class="fas fa-check-circle me-2"></i>Correct! The word is ' + currentWord + '</span>';
                resultDiv.style.display = 'block';
                completeGame('word');
                setTimeout(() => {
                    bootstrap.Modal.getInstance(document.getElementById('wordGameModal')).hide();
                }, 1500);
            } else {
                resultDiv.innerHTML = '<span style="color: #EF4444;"><i class="fas fa-times-circle me-2"></i>Try again!</span>';
                resultDiv.style.display = 'block';
            }
        }

        // Listen for Enter key in word input
        document.getElementById('wordGuess')?.addEventListener('keypress', function(e) {
            if (e.key === 'Enter') checkWord();
        });
    </script>
}
