<div class="wellness-container">
    <!-- Header with Progress -->
    <div class="wellness-header">
        <div class="header-content">
            <h1 class="header-title">
                @if (isMaintenancePlan)
                {
                    <i class="fas fa-leaf me-2"></i>@:Your Wellness Maintenance Plan
                }
                else
                {
                    <i class="fas fa-heart-pulse me-2"></i>@:Your 7-Day Wellness Journey
                }
            </h1>
            <p class="header-subtitle">
                @if (isMaintenancePlan)
                {
                    @:Keep up your healthy habits with these daily wellness tasks! 🌟
                }
                else
                {
                    @:Complete daily tasks to improve your mental wellbeing. You've got this! 💪
                }
            </p>
            <div class="progress-wrapper">
                <div class="progress-info">
                    <div class="progress-label">Overall Progress</div>
                    <div class="progress-bar-container">
                        <div class="progress-bar-fill" id="progressBar" style="width: @Model.ProgressPercentage%"></div>
                    </div>
                </div>
                <div class="progress-stats">
                    <div class="stat-big" id="progressPercent">@Model.ProgressPercentage%</div>
                    <div class="stat-label"><span id="completedCount">@Model.CompletedTasks</span> of @Model.TotalTasks tasks</div>
                </div>
            </div>
        </div>
    </div>

    <!-- Day Tabs -->
    <div class="day-tabs" id="dayTabs">
        @foreach (var day in Model.Days)
        {
            var isActive = day.Day == currentDay;
            var isCompleted = day.IsCompleted;
            var isLocked = day.Day > currentDay;
            <a href="javascript:void(0)" 
               class="day-tab @(isActive ? "active" : "") @(isCompleted ? "completed" : "") @(isLocked ? "locked" : "")" 
               data-day="@day.Day"
               onclick="@(isLocked ? "showLockedMessage(" + day.Day + ")" : "showDay(" + day.Day + ")")">
                <div class="day-number">@day.Day</div>
                <div class="day-name">@day.DayName.Substring(0, 3)</div>
                @if (isLocked)
                {
                    <div class="lock-icon"><i class="fas fa-lock"></i></div>
                }
            </a>
        }
    </div>

    <!-- Day Content -->
    @foreach (var day in Model.Days)
    {
        var isActive = day.Day == currentDay;
        var isLocked = day.Day > currentDay;
        var placeTasks = day.Tasks.Where(t => t.Category == "place_visit").ToList();
        var otherTasks = day.Tasks.Where(t => t.Category != "place_visit").ToList();
        var dayGamesCompleted = ViewBag.GamesCompleted ?? new Dictionary<int, List<string>>();
        <div class="day-content" id="day-@day.Day" style="display: @(isActive ? "block" : "none");">
            @if (isLocked)
            {
                <!-- Locked Day Overlay -->
                <div class="locked-overlay">
                    <div class="lock-icon-big"><i class="fas fa-lock"></i></div>
                    <h3>Day @day.Day is Locked</h3>
                    <p>Complete the previous days first! This day will unlock automatically.</p>
                    <div class="unlock-date">
                        <i class="fas fa-calendar-alt me-2"></i>Unlocks on @day.Date
                    </div>
                </div>
            }
            else
            {
            <!-- Affirmation -->
            <div class="affirmation-card">
                <div class="affirmation-icon">✨</div>
                <div class="affirmation-text">"@day.Affirmation"</div>
            </div>

            <!-- Featured Place Tasks (Priority) -->
            @if (placeTasks.Any())
            {
                foreach (var task in placeTasks)
                {
                    <div class="featured-place-task @(task.IsCompleted ? "completed-featured" : "")" id="task-@task.Id" data-task-id="@task.Id">
                        <span class="featured-badge"><i class="fas fa-star me-1"></i>TODAY'S ADVENTURE</span>
                        <div class="featured-icon">
                            <i class="fas @task.Icon"></i>
                        </div>
                        <div class="featured-category">@task.CategoryName</div>
                        <h3 class="featured-title">@task.Title</h3>
                        <p class="featured-desc">@task.Description</p>

                        @if (task.RequiresLocation && task.SuggestedPlace != null)
                        {
                            <div class="featured-place-card">
                                @if (!string.IsNullOrEmpty(task.SuggestedPlace.PhotoUrl))
                                {
                                    <img src="@task.SuggestedPlace.PhotoUrl" alt="@task.SuggestedPlace.Name" class="place-img">
                                }
                                else
                                {
                                    <div class="place-img" style="display: flex; align-items: center; justify-content: center;">
                                        <i class="fas fa-map-marker-alt" style="font-size: 1.3rem; opacity: 0.7;"></i>
                                    </div>
                                }
                                <div style="flex: 1;">
                                    <div class="place-name">@task.SuggestedPlace.Name</div>
                                    <div class="place-addr">@task.SuggestedPlace.Address</div>
                                    <div>
                                        @if (task.SuggestedPlace.Rating.HasValue)
                                        {
                                            <span class="place-meta-item"><i class="fas fa-star"></i> @task.SuggestedPlace.Rating.Value.ToString("0.0")</span>
                                        }
                                        @if (!string.IsNullOrEmpty(task.SuggestedPlace.Distance))
                                        {
                                            <span class="place-meta-item"><i class="fas fa-location-dot"></i> @task.SuggestedPlace.Distance</span>
                                        }
                                        @if (task.SuggestedPlace.IsOpen.HasValue && task.SuggestedPlace.IsOpen.Value)
                                        {
                                            <span class="place-meta-item" style="background: rgba(16,185,129,0.3);"><i class="fas fa-clock"></i> Open</span>
                                        }
                                    </div>
                                </div>
                            </div>
                            <div class="featured-actions">
                                <a href="https://www.google.com/maps/dir/?api=1&destination=@task.SuggestedPlace.Latitude,@task.SuggestedPlace.Longitude" 
                                   target="_blank" class="btn-featured btn-directions-white">
                                    <i class="fas fa-directions me-1"></i> Get Directions
                                </a>
                                @if (!task.IsCompleted)
                                {
                                    <button class="btn-featured btn-complete-white" onclick="completeTask('@task.Id')">
                                        <i class="fas fa-check me-1"></i> Mark Complete
                                    </button>
                                    <button class="btn-featured" style="background: rgba(255,255,255,0.2);" onclick="changePlace('@task.Id', '@task.PlaceType')">
                                        <i class="fas fa-sync-alt me-1"></i> Change Place
                                    </button>
                                }
                                else
                                {
                                    <span class="btn-featured" style="background: rgba(255,255,255,0.3);"><i class="fas fa-check-circle me-1"></i> Completed!</span>
                                }
                            </div>
                        }
                        else if (task.RequiresLocation && task.SuggestedPlace == null)
                        {
                            <!-- Auto-loaded places section -->
                            <div class="auto-places-section" id="autoPlaces-@task.Id" data-task-id="@task.Id" data-place-type="@task.PlaceType">
                                <div class="auto-places-loading">
                                    <i class="fas fa-spinner fa-spin"></i> Finding nearby places...
                                </div>
                            </div>
                            <div class="featured-actions">
                                <button class="btn-featured btn-find-white" onclick="findPlaces('@task.Id', '@task.PlaceType')">
                                    <i class="fas fa-compass me-1"></i> Discover More Places
                                </button>
                            </div>
                        }
                        else if (!task.IsCompleted)
                        {
                            <div class="featured-actions">
                                <button class="btn-featured btn-complete-white" onclick="completeTask('@task.Id')">
                                    <i class="fas fa-check me-1"></i> Mark Complete
                                </button>
                            </div>
                        }
                    </div>
                }
            }

            <!-- Mini Games Section -->
            <div class="games-section">
                <div class="games-header">
                    <div class="games-title"><i class="fas fa-gamepad"></i> Daily Mind Games</div>
                    <div class="games-progress" id="gamesProgress-@day.Day"><span id="gamesCount-@day.Day">0</span>/4 completed</div>
                </div>
                <div class="games-grid">
                    <div class="game-card" onclick="playGame('breathing', @day.Day)" id="game-breathing-@day.Day">
                        <div class="game-icon">🧘</div>
                        <div class="game-name">Breathing</div>
                        <div class="game-points">+10 pts</div>
                    </div>
                    <div class="game-card" onclick="playGame('memory', @day.Day)" id="game-memory-@day.Day">
                        <div class="game-icon">🧠</div>
                        <div class="game-name">Memory</div>
                        <div class="game-points">+15 pts</div>
                    </div>
                    <div class="game-card" onclick="playGame('gratitude', @day.Day)" id="game-gratitude-@day.Day">
                        <div class="game-icon">💝</div>
                        <div class="game-name">Gratitude</div>
                        <div class="game-points">+10 pts</div>
                    </div>
                    <div class="game-card" onclick="playGame('word', @day.Day)" id="game-word-@day.Day">
                        <div class="game-icon">📝</div>
                        <div class="game-name">Word Puzzle</div>
                        <div class="game-points">+15 pts</div>
                    </div>
                </div>
            </div>

            <!-- Other Tasks -->
            <div class="tasks-grid">
                @foreach (var task in otherTasks)
                {
                    <div class="task-card @(task.IsCompleted ? "completed" : "")" id="task-@task.Id" data-task-id="@task.Id">
                        <div class="task-icon" style="background: @(task.Color)22; color: @task.Color;">
                            <i class="fas @task.Icon"></i>
                        </div>
                        <div class="task-content">
                            <div class="task-category" style="color: @task.Color;">@task.CategoryName</div>
                            <h3 class="task-title">@task.Title</h3>
                            <p class="task-description">@task.Description</p>
                            <div class="task-meta">
                                <div class="task-meta-item">
                                    <i class="fas fa-clock"></i>
                                    <span>@task.Duration</span>
                                </div>
                                @if (task.IsCompleted && task.CompletedAt.HasValue)
                                {
                                    <div class="task-meta-item" style="color: var(--secondary);">
                                        <i class="fas fa-check-circle"></i>
                                        <span>Completed @task.CompletedAt.Value.ToString("MMM dd, h:mm tt")</span>
                                    </div>
                                }
                            </div>
                        </div>
                        <div class="task-actions">
                            @if (!task.IsCompleted)
                            {
                                <button class="btn-complete" onclick="completeTask('@task.Id')">
                                    <i class="fas fa-check me-1"></i> Complete
                                </button>
                            }
                            else
                            {
                                <div style="color: var(--secondary); font-weight: 600; font-size: 0.85rem;">
                                    <i class="fas fa-check-circle me-1"></i> Done
                                </div>
                            }
                        </div>
                    </div>
                }
            </div>
            } <!-- End of else (unlocked day) -->
        </div>
    }

    <!-- Recommendations -->
    <div class="recommendations-section">
        <h2 class="section-title">
            <i class="fas fa-lightbulb" style="color: var(--accent);"></i>
            Professional Recommendations
        </h2>
        <ul class="recommendations-list">
            @foreach (var rec in Model.Recommendations)
            {
                <li>
                    <i class="fas fa-check-circle"></i>
                    <span>@rec</span>
                </li>
            }
        </ul>
    </div>
</div>

