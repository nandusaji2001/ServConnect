@using ServConnect.Models.Community
@model List<ServConnect.Models.Community.BanAppeal>

@{
    ViewData["Title"] = "Ban Appeals";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<style>
    :root {
        --admin-primary: #3b82f6;
        --admin-warning: #fbbf24;
        --admin-success: #10B981;
        --admin-danger: #dc2626;
        --bg-light: #ffffff;
        --text-primary: #1f2937;
        --text-secondary: #6b7280;
        --shadow-card: 0 4px 20px rgba(0, 0, 0, 0.08);
    }

    body {
        background: linear-gradient(180deg, #f9fafb 0%, #ffffff 100%);
    }

    .admin-container {
        padding: 30px 20px 80px;
        max-width: 1400px;
        margin: 0 auto;
    }

    /* Compact Header */
    .page-header {
        background: white;
        border-radius: 16px;
        padding: 24px 32px;
        margin-bottom: 30px;
        box-shadow: var(--shadow-card);
        display: flex;
        justify-content: space-between;
        align-items: center;
        animation: fadeInDown 0.5s ease-out;
    }

    .page-header-content h1 {
        font-size: 1.75rem;
        font-weight: 700;
        color: var(--text-primary);
        margin: 0 0 4px 0;
        display: flex;
        align-items: center;
        gap: 12px;
    }

    .page-header-content h1 i {
        color: var(--admin-warning);
    }

    .page-header-content p {
        margin: 0;
        color: var(--text-secondary);
        font-size: 0.9rem;
    }

    .back-btn-modern {
        padding: 10px 20px;
        background: #f3f4f6;
        color: var(--text-primary);
        border-radius: 10px;
        text-decoration: none;
        font-weight: 500;
        transition: all 0.3s ease;
        display: inline-flex;
        align-items: center;
        gap: 8px;
    }

    .back-btn-modern:hover {
        background: #e5e7eb;
        transform: translateX(-3px);
        text-decoration: none;
        color: var(--text-primary);
    }

    /* Filter Tabs */
    .filter-tabs {
        background: white;
        border-radius: 16px;
        padding: 20px;
        margin-bottom: 30px;
        box-shadow: var(--shadow-card);
        animation: fadeInUp 0.5s ease-out 0.1s both;
    }

    .tab-group {
        display: flex;
        gap: 12px;
        flex-wrap: wrap;
    }

    .tab-btn {
        padding: 10px 24px;
        border-radius: 10px;
        border: 2px solid transparent;
        background: #f3f4f6;
        color: var(--text-secondary);
        text-decoration: none;
        font-weight: 600;
        transition: all 0.3s ease;
        display: inline-flex;
        align-items: center;
        gap: 8px;
    }

    .tab-btn:hover {
        background: #e5e7eb;
        text-decoration: none;
        color: var(--text-primary);
    }

    .tab-btn.active {
        background: linear-gradient(135deg, #fbbf24 0%, #f59e0b 100%);
        color: white;
        border-color: #f59e0b;
    }

    .tab-btn.active-success {
        background: linear-gradient(135deg, #10B981 0%, #059669 100%);
        color: white;
        border-color: #059669;
    }

    .tab-btn.active-danger {
        background: linear-gradient(135deg, #dc2626 0%, #b91c1c 100%);
        color: white;
        border-color: #b91c1c;
    }

    .tab-btn.active-primary {
        background: linear-gradient(135deg, #3b82f6 0%, #2563eb 100%);
        color: white;
        border-color: #2563eb;
    }

    /* Appeals Grid */
    .appeals-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(380px, 1fr));
        gap: 24px;
        animation: fadeInUp 0.5s ease-out 0.2s both;
    }

    /* Appeal Card */
    .appeal-card {
        background: white;
        border-radius: 16px;
        overflow: hidden;
        box-shadow: var(--shadow-card);
        transition: all 0.3s ease;
        display: flex;
        flex-direction: column;
    }

    .appeal-card:hover {
        transform: translateY(-4px);
        box-shadow: 0 12px 30px rgba(0, 0, 0, 0.12);
    }

    .appeal-card-header {
        padding: 20px;
        color: white;
        display: flex;
        justify-content: space-between;
        align-items: center;
    }

    .appeal-card-header.pending {
        background: linear-gradient(135deg, #fbbf24 0%, #f59e0b 100%);
    }

    .appeal-card-header.approved {
        background: linear-gradient(135deg, #10B981 0%, #059669 100%);
    }

    .appeal-card-header.rejected {
        background: linear-gradient(135deg, #dc2626 0%, #b91c1c 100%);
    }

    .appeal-card-header h3 {
        font-size: 1.1rem;
        font-weight: 700;
        margin: 0;
        display: flex;
        align-items: center;
        gap: 8px;
    }

    .level-badge {
        background: rgba(255, 255, 255, 0.3);
        padding: 4px 12px;
        border-radius: 20px;
        font-size: 0.85rem;
        font-weight: 600;
    }

    .appeal-card-body {
        padding: 20px;
        flex: 1;
        display: flex;
        flex-direction: column;
    }

    .info-item {
        display: flex;
        align-items: center;
        gap: 8px;
        margin-bottom: 12px;
        color: var(--text-secondary);
        font-size: 0.9rem;
    }

    .info-item i {
        color: var(--admin-primary);
        width: 16px;
    }

    .section-label {
        font-weight: 600;
        color: var(--text-primary);
        margin-bottom: 6px;
        font-size: 0.9rem;
    }

    .section-content {
        color: var(--text-secondary);
        font-size: 0.9rem;
        line-height: 1.5;
        margin-bottom: 16px;
    }

    .status-alert {
        padding: 12px;
        border-radius: 10px;
        margin-top: 16px;
        font-size: 0.85rem;
    }

    .status-alert.success {
        background: linear-gradient(135deg, #d1fae5 0%, #a7f3d0 100%);
        color: #065f46;
    }

    .status-alert.danger {
        background: linear-gradient(135deg, #fee2e2 0%, #fecaca 100%);
        color: #991b1b;
    }

    .status-alert strong {
        display: block;
        margin-bottom: 4px;
    }

    .appeal-card-footer {
        padding: 16px 20px;
        background: #f9fafb;
        border-top: 1px solid #e5e7eb;
    }

    .view-btn {
        display: block;
        width: 100%;
        padding: 12px;
        background: linear-gradient(135deg, #3b82f6 0%, #2563eb 100%);
        color: white;
        border-radius: 10px;
        text-decoration: none;
        font-weight: 600;
        text-align: center;
        transition: all 0.3s ease;
    }

    .view-btn:hover {
        transform: translateY(-2px);
        box-shadow: 0 4px 12px rgba(59, 130, 246, 0.3);
        color: white;
        text-decoration: none;
    }

    /* Empty State */
    .empty-state {
        background: white;
        border-radius: 16px;
        padding: 60px 40px;
        text-align: center;
        box-shadow: var(--shadow-card);
    }

    .empty-state i {
        font-size: 4rem;
        color: #d1d5db;
        margin-bottom: 20px;
    }

    .empty-state h3 {
        color: var(--text-primary);
        margin-bottom: 8px;
    }

    .empty-state p {
        color: var(--text-secondary);
    }

    /* Animations */
    @@keyframes fadeInDown {
        from {
            opacity: 0;
            transform: translateY(-20px);
        }
        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    @@keyframes fadeInUp {
        from {
            opacity: 0;
            transform: translateY(20px);
        }
        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    /* Responsive */
    @@media (max-width: 768px) {
        .admin-container {
            padding: 20px 16px 60px;
        }

        .page-header {
            flex-direction: column;
            gap: 16px;
            align-items: flex-start;
        }

        .page-header-content h1 {
            font-size: 1.5rem;
        }

        .appeals-grid {
            grid-template-columns: 1fr;
        }

        .tab-group {
            flex-direction: column;
        }

        .tab-btn {
            width: 100%;
            justify-content: center;
        }
    }
</style>

<div class="admin-container">
    <!-- Compact Header -->
    <div class="page-header">
        <div class="page-header-content">
            <h1><i class="fas fa-gavel"></i> Ban Appeals</h1>
            <p>Review and manage user ban appeal requests</p>
        </div>
        <a asp-action="Dashboard" class="back-btn-modern">
            <i class="fas fa-arrow-left"></i> Dashboard
        </a>
    </div>

    <!-- Filter Tabs -->
    <div class="filter-tabs">
        <div class="tab-group">
            <a asp-action="BanAppeals" asp-route-status="all" 
               class="tab-btn @(ViewBag.CurrentStatus == "all" ? "active-primary" : "")">
                <i class="fas fa-list"></i> All Appeals
            </a>
            <a asp-action="BanAppeals" asp-route-status="pending" 
               class="tab-btn @(ViewBag.CurrentStatus == "pending" ? "active" : "")">
                <i class="fas fa-clock"></i> Pending
            </a>
            <a asp-action="BanAppeals" asp-route-status="approved" 
               class="tab-btn @(ViewBag.CurrentStatus == "approved" ? "active-success" : "")">
                <i class="fas fa-check-circle"></i> Approved
            </a>
            <a asp-action="BanAppeals" asp-route-status="rejected" 
               class="tab-btn @(ViewBag.CurrentStatus == "rejected" ? "active-danger" : "")">
                <i class="fas fa-times-circle"></i> Rejected
            </a>
        </div>
    </div>

    <!-- Appeals Grid -->
    @if (Model == null || !Model.Any())
    {
        <div class="empty-state">
            <i class="fas fa-inbox"></i>
            <h3>No Appeals Found</h3>
            <p>There are no ban appeals matching your current filter.</p>
        </div>
    }
    else
    {
        <div class="appeals-grid">
            @foreach (var appeal in Model)
            {
                <div class="appeal-card">
                    <div class="appeal-card-header @(appeal.Status == AppealStatus.Pending ? "pending" : appeal.Status == AppealStatus.Approved ? "approved" : "rejected")">
                        <h3>
                            <i class="fas fa-user"></i> @appeal.Username
                        </h3>
                        <span class="level-badge">Level @appeal.BanLevel</span>
                    </div>

                    <div class="appeal-card-body">
                        <div class="info-item">
                            <i class="fas fa-envelope"></i>
                            <span>@appeal.UserEmail</span>
                        </div>

                        @if (!string.IsNullOrEmpty(appeal.ContactPhone))
                        {
                            <div class="info-item">
                                <i class="fas fa-phone"></i>
                                <span>@appeal.ContactPhone</span>
                            </div>
                        }

                        <div class="info-item">
                            <i class="fas fa-clock"></i>
                            <span>@appeal.SubmittedAt.ToString("MMM dd, yyyy")</span>
                        </div>

                        @if (appeal.BanExpiresAt != DateTime.MaxValue)
                        {
                            <div class="info-item">
                                <i class="fas fa-calendar"></i>
                                <span>Expires: @appeal.BanExpiresAt.ToString("MMM dd, yyyy")</span>
                            </div>
                        }
                        else
                        {
                            <div class="info-item" style="color: #dc2626;">
                                <i class="fas fa-ban"></i>
                                <span>Permanent Ban</span>
                            </div>
                        }

                        <div style="margin-top: 16px;">
                            <div class="section-label">Ban Reason</div>
                            <div class="section-content">@appeal.BanReason</div>
                        </div>

                        <div>
                            <div class="section-label">User's Explanation</div>
                            <div class="section-content">
                                @(appeal.Issue.Length > 120 ? appeal.Issue.Substring(0, 120) + "..." : appeal.Issue)
                            </div>
                        </div>

                        @if (appeal.Status != AppealStatus.Pending)
                        {
                            <div class="status-alert @(appeal.Status == AppealStatus.Approved ? "success" : "danger")">
                                <strong>@appeal.Status by @appeal.ReviewedBy</strong>
                                @appeal.AdminResponse
                            </div>
                        }
                    </div>

                    <div class="appeal-card-footer">
                        <a asp-action="AppealDetails" asp-route-id="@appeal.Id" class="view-btn">
                            <i class="fas fa-eye"></i> View Details & Review
                        </a>
                    </div>
                </div>
            }
        </div>
    }
</div>
