@{
    ViewData["Title"] = "Submit Ban Appeal";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<style>
    :root {
        --warning-primary: #fbbf24;
        --warning-dark: #f59e0b;
        --warning-light: #fef3c7;
        --primary: #10B981;
        --bg-light: #ffffff;
        --text-primary: #1f2937;
        --text-secondary: #6b7280;
        --shadow-card: 0 4px 20px rgba(251, 191, 36, 0.1);
        --shadow-card-hover: 0 20px 40px rgba(251, 191, 36, 0.15);
    }

    body {
        background: linear-gradient(180deg, #fffbeb 0%, #fef3c7 30%, #ffffff 100%);
        min-height: 100vh;
    }

    .appeal-container {
        padding: 40px 20px 80px;
        max-width: 1200px;
        margin: 0 auto;
    }

    /* Hero Section */
    .appeal-hero {
        text-align: center;
        margin-bottom: 50px;
        animation: fadeInDown 0.8s ease-out;
        background: linear-gradient(135deg, #fbbf24 0%, #f59e0b 100%);
        border-radius: 24px;
        padding: 60px 40px;
        color: white;
        box-shadow: 0 20px 60px rgba(251, 191, 36, 0.3);
        position: relative;
        overflow: hidden;
    }

    .appeal-hero::before {
        content: '';
        position: absolute;
        top: -50%;
        right: -20%;
        width: 400px;
        height: 400px;
        background: radial-gradient(circle, rgba(255,255,255,0.15) 0%, transparent 60%);
        pointer-events: none;
    }

    .appeal-icon {
        width: 100px;
        height: 100px;
        background: rgba(255, 255, 255, 0.2);
        backdrop-filter: blur(10px);
        border-radius: 50%;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        font-size: 3rem;
        margin-bottom: 20px;
        border: 3px solid rgba(255, 255, 255, 0.3);
    }

    .appeal-hero h1 {
        font-size: 3rem;
        font-weight: 800;
        margin-bottom: 12px;
        position: relative;
        z-index: 1;
    }

    .appeal-hero p {
        font-size: 1.2rem;
        opacity: 0.95;
        position: relative;
        z-index: 1;
    }

    /* Content Grid */
    .appeal-content-grid {
        display: grid;
        grid-template-columns: 1fr 400px;
        gap: 30px;
        animation: fadeInUp 0.8s ease-out 0.3s both;
    }

    /* Form Card */
    .form-card {
        background: white;
        border-radius: 24px;
        padding: 40px;
        box-shadow: var(--shadow-card);
    }

    .form-card h2 {
        font-size: 1.5rem;
        font-weight: 700;
        color: var(--text-primary);
        margin-bottom: 24px;
        display: flex;
        align-items: center;
        gap: 12px;
    }

    .form-card h2 i {
        color: var(--warning-primary);
    }

    .info-banner {
        background: linear-gradient(135deg, #dbeafe 0%, #bfdbfe 100%);
        border-left: 4px solid #3b82f6;
        border-radius: 12px;
        padding: 16px 20px;
        margin-bottom: 30px;
        display: flex;
        align-items: flex-start;
        gap: 12px;
    }

    .info-banner i {
        color: #3b82f6;
        font-size: 1.2rem;
        margin-top: 2px;
    }

    .info-banner p {
        margin: 0;
        color: #1e40af;
        font-size: 0.95rem;
        line-height: 1.6;
    }

    /* Form Styling */
    .form-group-modern {
        margin-bottom: 24px;
    }

    .form-label-modern {
        display: block;
        font-weight: 600;
        color: var(--text-primary);
        margin-bottom: 8px;
        font-size: 0.95rem;
    }

    .form-label-modern .required {
        color: #dc2626;
        margin-left: 4px;
    }

    .form-input-modern {
        width: 100%;
        padding: 14px 16px;
        border: 2px solid #e5e7eb;
        border-radius: 12px;
        font-size: 1rem;
        transition: all 0.3s ease;
        background: #f9fafb;
    }

    .form-input-modern:focus {
        outline: none;
        border-color: var(--warning-primary);
        background: white;
        box-shadow: 0 0 0 4px rgba(251, 191, 36, 0.1);
    }

    .form-textarea-modern {
        width: 100%;
        padding: 14px 16px;
        border: 2px solid #e5e7eb;
        border-radius: 12px;
        font-size: 1rem;
        transition: all 0.3s ease;
        background: #f9fafb;
        resize: vertical;
        min-height: 150px;
        font-family: inherit;
    }

    .form-textarea-modern:focus {
        outline: none;
        border-color: var(--warning-primary);
        background: white;
        box-shadow: 0 0 0 4px rgba(251, 191, 36, 0.1);
    }

    .form-hint {
        display: block;
        margin-top: 6px;
        font-size: 0.85rem;
        color: var(--text-secondary);
    }

    /* Buttons */
    .btn-modern {
        display: block;
        width: 100%;
        padding: 16px 24px;
        border-radius: 12px;
        font-weight: 600;
        font-size: 1.05rem;
        text-decoration: none;
        transition: all 0.3s ease;
        border: none;
        cursor: pointer;
        margin-bottom: 12px;
        text-align: center;
    }

    .btn-modern:last-child {
        margin-bottom: 0;
    }

    .btn-primary-modern {
        background: linear-gradient(135deg, #fbbf24 0%, #f59e0b 100%);
        color: white;
        box-shadow: 0 4px 12px rgba(251, 191, 36, 0.3);
    }

    .btn-primary-modern:hover {
        transform: translateY(-2px);
        box-shadow: 0 8px 20px rgba(251, 191, 36, 0.4);
        color: white;
        text-decoration: none;
    }

    .btn-secondary-modern {
        background: #f3f4f6;
        color: var(--text-primary);
    }

    .btn-secondary-modern:hover {
        background: #e5e7eb;
        transform: translateY(-2px);
        text-decoration: none;
        color: var(--text-primary);
    }

    /* Sidebar */
    .sidebar-section {
        display: flex;
        flex-direction: column;
        gap: 24px;
    }

    /* Guidelines Card */
    .guidelines-card {
        background: white;
        border-radius: 24px;
        padding: 28px;
        box-shadow: var(--shadow-card);
    }

    .guidelines-card h3 {
        font-size: 1.2rem;
        font-weight: 700;
        color: var(--text-primary);
        margin-bottom: 16px;
        display: flex;
        align-items: center;
        gap: 8px;
    }

    .guidelines-card h3 i {
        color: var(--warning-primary);
    }

    .guidelines-card ul {
        list-style: none;
        padding: 0;
        margin: 0;
    }

    .guidelines-card li {
        padding: 12px 0;
        color: var(--text-secondary);
        font-size: 0.9rem;
        display: flex;
        align-items: flex-start;
        gap: 12px;
        border-bottom: 1px solid #f3f4f6;
    }

    .guidelines-card li:last-child {
        border-bottom: none;
    }

    .guidelines-card li i {
        color: var(--warning-primary);
        margin-top: 3px;
        flex-shrink: 0;
    }

    /* Process Card */
    .process-card {
        background: linear-gradient(135deg, #f0fdf4 0%, #dcfce7 100%);
        border-radius: 24px;
        padding: 28px;
        box-shadow: var(--shadow-card);
        border: 2px solid #10B981;
    }

    .process-card h3 {
        font-size: 1.2rem;
        font-weight: 700;
        color: #065f46;
        margin-bottom: 16px;
        display: flex;
        align-items: center;
        gap: 8px;
    }

    .process-step {
        display: flex;
        align-items: flex-start;
        gap: 12px;
        margin-bottom: 16px;
    }

    .process-step:last-child {
        margin-bottom: 0;
    }

    .step-number {
        width: 32px;
        height: 32px;
        background: white;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-weight: 700;
        color: #10B981;
        flex-shrink: 0;
        box-shadow: 0 2px 8px rgba(16, 185, 129, 0.2);
    }

    .step-content {
        flex: 1;
        padding-top: 4px;
    }

    .step-content strong {
        display: block;
        color: #065f46;
        margin-bottom: 4px;
    }

    .step-content p {
        margin: 0;
        color: #047857;
        font-size: 0.85rem;
    }

    /* Alert Messages */
    .alert-modern {
        padding: 16px 20px;
        border-radius: 12px;
        margin-bottom: 20px;
        display: none;
        align-items: flex-start;
        gap: 12px;
    }

    .alert-modern.show {
        display: flex;
    }

    .alert-success-modern {
        background: linear-gradient(135deg, #d1fae5 0%, #a7f3d0 100%);
        border-left: 4px solid #10B981;
        color: #065f46;
    }

    .alert-error-modern {
        background: linear-gradient(135deg, #fee2e2 0%, #fecaca 100%);
        border-left: 4px solid #dc2626;
        color: #991b1b;
    }

    .alert-modern i {
        font-size: 1.2rem;
        margin-top: 2px;
    }

    /* Animations */
    @@keyframes fadeInDown {
        from {
            opacity: 0;
            transform: translateY(-30px);
        }
        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    @@keyframes fadeInUp {
        from {
            opacity: 0;
            transform: translateY(30px);
        }
        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    /* Responsive */
    @@media (max-width: 1024px) {
        .appeal-content-grid {
            grid-template-columns: 1fr;
        }

        .sidebar-section {
            display: grid;
            grid-template-columns: repeat(2, 1fr);
            gap: 24px;
        }
    }

    @@media (max-width: 768px) {
        .appeal-container {
            padding: 20px 16px 60px;
        }

        .appeal-hero {
            padding: 40px 24px;
        }

        .appeal-hero h1 {
            font-size: 2rem;
        }

        .appeal-hero p {
            font-size: 1rem;
        }

        .sidebar-section {
            grid-template-columns: 1fr;
        }

        .form-card {
            padding: 28px 24px;
        }
    }
</style>

<div class="appeal-container">
    <!-- Hero Section -->
    <div class="appeal-hero">
        <div class="appeal-icon">
            <i class="fas fa-gavel"></i>
        </div>
        <h1>Submit Ban Appeal</h1>
        <p>Request a review of your community ban by our moderation team</p>
    </div>

    <!-- Content Grid -->
    <div class="appeal-content-grid">
        <!-- Form Section -->
        <div class="form-card">
            <h2><i class="fas fa-file-alt"></i> Appeal Form</h2>

            <div class="info-banner">
                <i class="fas fa-info-circle"></i>
                <p>Your community account has been banned. Submit an appeal to have your case reviewed by our moderation team. Be honest and respectful in your explanation.</p>
            </div>

            <div id="successMessage" class="alert-modern alert-success-modern">
                <i class="fas fa-check-circle"></i>
                <div>
                    <strong>Appeal Submitted Successfully!</strong>
                    <p>An administrator will review your appeal soon. You'll receive an email with the decision.</p>
                </div>
            </div>

            <div id="errorMessage" class="alert-modern alert-error-modern">
                <i class="fas fa-exclamation-circle"></i>
                <div id="errorText"></div>
            </div>

            <form id="appealForm">
                <div class="form-group-modern">
                    <label for="email" class="form-label-modern">
                        Email Address<span class="required">*</span>
                    </label>
                    <input type="email" class="form-input-modern" id="email" required 
                           placeholder="your.email@example.com">
                    <span class="form-hint">We'll use this to contact you about your appeal decision</span>
                </div>

                <div class="form-group-modern">
                    <label for="phone" class="form-label-modern">Contact Phone</label>
                    <input type="tel" class="form-input-modern" id="phone" 
                           placeholder="+1 (555) 000-0000">
                    <span class="form-hint">Optional - Provide if you'd like to be contacted by phone</span>
                </div>

                <div class="form-group-modern">
                    <label for="issue" class="form-label-modern">
                        Explain Your Situation<span class="required">*</span>
                    </label>
                    <textarea class="form-textarea-modern" id="issue" required 
                              placeholder="Please explain why you believe your ban should be lifted. Include any relevant context or circumstances that might help your case..."></textarea>
                    <span class="form-hint">Be detailed and honest. Admins will review your explanation carefully</span>
                </div>

                <button type="submit" class="btn-modern btn-primary-modern">
                    <i class="fas fa-paper-plane"></i> Submit Appeal
                </button>
                <a href="/Community/Banned" class="btn-modern btn-secondary-modern">
                    <i class="fas fa-arrow-left"></i> Go Back
                </a>
            </form>
        </div>

        <!-- Sidebar -->
        <div class="sidebar-section">
            <!-- Appeal Process -->
            <div class="process-card">
                <h3><i class="fas fa-list-ol"></i> Appeal Process</h3>
                <div class="process-step">
                    <div class="step-number">1</div>
                    <div class="step-content">
                        <strong>Submit Appeal</strong>
                        <p>Fill out the form with your explanation</p>
                    </div>
                </div>
                <div class="process-step">
                    <div class="step-number">2</div>
                    <div class="step-content">
                        <strong>Admin Review</strong>
                        <p>Our team reviews your case and history</p>
                    </div>
                </div>
                <div class="process-step">
                    <div class="step-number">3</div>
                    <div class="step-content">
                        <strong>Decision</strong>
                        <p>You'll receive an email with the outcome</p>
                    </div>
                </div>
                <div class="process-step">
                    <div class="step-number">4</div>
                    <div class="step-content">
                        <strong>Resolution</strong>
                        <p>Ban lifted or upheld based on review</p>
                    </div>
                </div>
            </div>

            <!-- Guidelines -->
            <div class="guidelines-card">
                <h3><i class="fas fa-lightbulb"></i> Appeal Tips</h3>
                <ul>
                    <li>
                        <i class="fas fa-check-circle"></i>
                        <span>Be honest and take responsibility for your actions</span>
                    </li>
                    <li>
                        <i class="fas fa-check-circle"></i>
                        <span>Explain any misunderstandings or context</span>
                    </li>
                    <li>
                        <i class="fas fa-check-circle"></i>
                        <span>Show that you understand the community guidelines</span>
                    </li>
                    <li>
                        <i class="fas fa-check-circle"></i>
                        <span>Remain respectful and professional</span>
                    </li>
                    <li>
                        <i class="fas fa-check-circle"></i>
                        <span>Provide specific details about your situation</span>
                    </li>
                </ul>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
    document.getElementById('appealForm').addEventListener('submit', async function(e) {
        e.preventDefault();

        const email = document.getElementById('email').value;
        const phone = document.getElementById('phone').value;
        const issue = document.getElementById('issue').value;

        // Hide previous messages
        document.getElementById('successMessage').classList.remove('show');
        document.getElementById('errorMessage').classList.remove('show');

        try {
            const response = await fetch('/api/community/appeal', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json'
                },
                body: JSON.stringify({ email, phone, issue })
            });

            const data = await response.json();

            if (response.ok) {
                document.getElementById('successMessage').classList.add('show');
                document.getElementById('appealForm').style.display = 'none';
                window.scrollTo({ top: 0, behavior: 'smooth' });
            } else {
                document.getElementById('errorText').textContent = data.error || 'Failed to submit appeal. Please try again.';
                document.getElementById('errorMessage').classList.add('show');
                window.scrollTo({ top: 0, behavior: 'smooth' });
            }
        } catch (error) {
            document.getElementById('errorText').textContent = 'An error occurred. Please try again later.';
            document.getElementById('errorMessage').classList.add('show');
            window.scrollTo({ top: 0, behavior: 'smooth' });
        }
    });
</script>
}

