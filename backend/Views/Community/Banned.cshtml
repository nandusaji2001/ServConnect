@model ServConnect.Models.Community.CommunityProfile

@{
    ViewData["Title"] = "Account Banned";
    Layout = "~/Views/Shared/_Layout.cshtml";
    var daysRemaining = Model.BanExpiresAt.HasValue ? (int)(Model.BanExpiresAt.Value - DateTime.UtcNow).TotalDays : -1;
    var isPermanent = !Model.BanExpiresAt.HasValue;
}

<style>
    .ban-warning {
        background: linear-gradient(135deg, #dc3545 0%, #c82333 100%);
        color: white;
        padding: 2rem;
        border-radius: 10px;
        box-shadow: 0 4px 6px rgba(0,0,0,0.1);
    }
    .ban-details-card {
        border-left: 4px solid #dc3545;
    }
    .countdown-box {
        background: #fff3cd;
        border: 2px solid #ffc107;
        border-radius: 8px;
        padding: 1.5rem;
        text-align: center;
    }
    .countdown-number {
        font-size: 3rem;
        font-weight: bold;
        color: #dc3545;
    }
</style>

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-10">
            <!-- Main Ban Warning -->
            <div class="ban-warning text-center mb-4">
                <i class="fas fa-ban fa-4x mb-3"></i>
                <h2 class="mb-2">Community Access Restricted</h2>
                <p class="lead mb-0">Your community account has been temporarily suspended</p>
            </div>

            <div class="row">
                <!-- Ban Details -->
                <div class="col-md-8">
                    <div class="card shadow-sm ban-details-card mb-4">
                        <div class="card-header bg-light">
                            <h5 class="mb-0"><i class="fas fa-info-circle"></i> Ban Information</h5>
                        </div>
                        <div class="card-body">
                            <div class="row mb-3">
                                <div class="col-sm-4 fw-bold">Reason:</div>
                                <div class="col-sm-8">@Model.BanReason</div>
                            </div>
                            <div class="row mb-3">
                                <div class="col-sm-4 fw-bold">Ban Level:</div>
                                <div class="col-sm-8">
                                    <span class="badge bg-danger">Level @Model.BanLevel</span>
                                </div>
                            </div>
                            <div class="row mb-3">
                                <div class="col-sm-4 fw-bold">Total Violations:</div>
                                <div class="col-sm-8">
                                    <span class="badge bg-warning text-dark">@Model.ViolationCount violations</span>
                                </div>
                            </div>
                            @if (!isPermanent)
                            {
                                <div class="row mb-3">
                                    <div class="col-sm-4 fw-bold">Expires On:</div>
                                    <div class="col-sm-8">@Model.BanExpiresAt.Value.ToString("MMMM dd, yyyy 'at' hh:mm tt UTC")</div>
                                </div>
                            }
                            else
                            {
                                <div class="row mb-3">
                                    <div class="col-sm-4 fw-bold">Duration:</div>
                                    <div class="col-sm-8">
                                        <span class="badge bg-dark">PERMANENT BAN</span>
                                    </div>
                                </div>
                            }
                        </div>
                    </div>

                    @if (Model.BanHistory.Any())
                    {
                        <div class="card shadow-sm mb-4">
                            <div class="card-header bg-light">
                                <h6 class="mb-0"><i class="fas fa-history"></i> Ban History</h6>
                            </div>
                            <div class="card-body">
                                <div class="table-responsive">
                                    <table class="table table-sm table-hover">
                                        <thead>
                                            <tr>
                                                <th>Date</th>
                                                <th>Duration</th>
                                                <th>Violations</th>
                                                <th>Reason</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            @foreach (var ban in Model.BanHistory.OrderByDescending(b => b.BannedAt))
                                            {
                                                <tr>
                                                    <td>@ban.BannedAt.ToString("MMM dd, yyyy")</td>
                                                    <td>
                                                        @if (ban.DurationDays == -1)
                                                        {
                                                            <span class="badge bg-dark">Permanent</span>
                                                        }
                                                        else
                                                        {
                                                            <span>@ban.DurationDays days</span>
                                                        }
                                                    </td>
                                                    <td>@ban.ViolationCount</td>
                                                    <td><small>@ban.Reason</small></td>
                                                </tr>
                                            }
                                        </tbody>
                                    </table>
                                </div>
                            </div>
                        </div>
                    }
                </div>

                <!-- Countdown & Actions -->
                <div class="col-md-4">
                    @if (!isPermanent && daysRemaining >= 0)
                    {
                        <div class="countdown-box mb-4">
                            <div class="countdown-number">@daysRemaining</div>
                            <div class="text-muted">@(daysRemaining == 1 ? "day" : "days") remaining</div>
                            <small class="text-muted d-block mt-2">
                                You can access community on<br/>
                                <strong>@Model.BanExpiresAt.Value.ToString("MMM dd, yyyy")</strong>
                            </small>
                        </div>
                    }
                    else if (isPermanent)
                    {
                        <div class="alert alert-dark text-center">
                            <i class="fas fa-infinity fa-2x mb-2"></i>
                            <p class="mb-0"><strong>Permanent Ban</strong></p>
                            <small>Only an admin can lift this ban</small>
                        </div>
                    }

                    <div class="card shadow-sm mb-3">
                        <div class="card-body text-center">
                            <h6 class="card-title">Need Help?</h6>
                            <p class="card-text small">Submit an appeal to have your case reviewed by an administrator.</p>
                            <a href="/Community/Appeal" class="btn btn-warning w-100 mb-2">
                                <i class="fas fa-gavel"></i> Submit Appeal
                            </a>
                            <a href="/" class="btn btn-outline-secondary w-100">
                                <i class="fas fa-home"></i> Return Home
                            </a>
                        </div>
                    </div>

                    <div class="card shadow-sm">
                        <div class="card-body">
                            <h6 class="card-title"><i class="fas fa-question-circle"></i> What Now?</h6>
                            <ul class="small mb-0">
                                <li>Submit an appeal with your explanation</li>
                                @if (!isPermanent)
                                {
                                    <li>Wait for the ban to expire automatically</li>
                                }
                                <li>Review community guidelines</li>
                                <li>Avoid future violations</li>
                            </ul>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
