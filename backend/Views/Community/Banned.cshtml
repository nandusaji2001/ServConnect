@model ServConnect.Models.Community.CommunityProfile

@{
    ViewData["Title"] = "Account Banned";
    Layout = "~/Views/Shared/_Layout.cshtml";
    var daysRemaining = Model.BanExpiresAt.HasValue ? (int)(Model.BanExpiresAt.Value - DateTime.UtcNow).TotalDays : -1;
    var isPermanent = !Model.BanExpiresAt.HasValue;
}

<style>
    :root {
        --danger-primary: #dc3545;
        --danger-dark: #c82333;
        --danger-light: #f8d7da;
        --warning-primary: #ffc107;
        --warning-dark: #e0a800;
        --bg-light: #ffffff;
        --bg-section: #fff5f5;
        --text-primary: #1f2937;
        --text-secondary: #6b7280;
        --shadow-card: 0 4px 20px rgba(220, 53, 69, 0.1);
        --shadow-card-hover: 0 20px 40px rgba(220, 53, 69, 0.15);
    }

    body {
        background: linear-gradient(180deg, #fff5f5 0%, #ffe5e5 30%, #ffffff 100%);
        min-height: 100vh;
    }

    .banned-container {
        padding: 40px 20px 80px;
        max-width: 1400px;
        margin: 0 auto;
    }

    /* Hero Section */
    .banned-hero {
        text-align: center;
        margin-bottom: 50px;
        animation: fadeInDown 0.8s ease-out;
        background: linear-gradient(135deg, #dc3545 0%, #c82333 100%);
        border-radius: 24px;
        padding: 60px 40px;
        color: white;
        box-shadow: 0 20px 60px rgba(220, 53, 69, 0.3);
        position: relative;
        overflow: hidden;
    }

    .banned-hero::before {
        content: '';
        position: absolute;
        top: -50%;
        right: -20%;
        width: 400px;
        height: 400px;
        background: radial-gradient(circle, rgba(255,255,255,0.15) 0%, transparent 60%);
        pointer-events: none;
    }

    .banned-hero::after {
        content: '';
        position: absolute;
        bottom: -30%;
        left: -10%;
        width: 300px;
        height: 300px;
        background: radial-gradient(circle, rgba(255,255,255,0.1) 0%, transparent 50%);
        pointer-events: none;
    }

    .banned-icon {
        width: 100px;
        height: 100px;
        background: rgba(255, 255, 255, 0.2);
        backdrop-filter: blur(10px);
        border-radius: 50%;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        font-size: 3rem;
        margin-bottom: 20px;
        border: 3px solid rgba(255, 255, 255, 0.3);
        animation: pulse 2s infinite;
    }

    .banned-hero h1 {
        font-size: 3rem;
        font-weight: 800;
        margin-bottom: 12px;
        position: relative;
        z-index: 1;
    }

    .banned-hero p {
        font-size: 1.2rem;
        opacity: 0.95;
        position: relative;
        z-index: 1;
    }

    /* Content Grid */
    .banned-content-grid {
        display: grid;
        grid-template-columns: 2fr 1fr;
        gap: 30px;
        animation: fadeInUp 0.8s ease-out 0.3s both;
    }

    /* Info Card */
    .info-card {
        background: white;
        border-radius: 24px;
        padding: 32px;
        box-shadow: var(--shadow-card);
        border-left: 4px solid var(--danger-primary);
    }

    .info-card h2 {
        font-size: 1.5rem;
        font-weight: 700;
        color: var(--text-primary);
        margin-bottom: 24px;
        display: flex;
        align-items: center;
        gap: 12px;
    }

    .info-card h2 i {
        color: var(--danger-primary);
    }

    .info-row {
        display: flex;
        padding: 16px 0;
        border-bottom: 1px solid #f3f4f6;
    }

    .info-row:last-child {
        border-bottom: none;
    }

    .info-label {
        font-weight: 600;
        color: var(--text-secondary);
        min-width: 140px;
    }

    .info-value {
        color: var(--text-primary);
        flex: 1;
    }

    .badge-custom {
        display: inline-block;
        padding: 6px 14px;
        border-radius: 50px;
        font-size: 0.85rem;
        font-weight: 600;
    }

    .badge-danger {
        background: linear-gradient(135deg, #fee2e2 0%, #fecaca 100%);
        color: #dc2626;
    }

    .badge-warning {
        background: linear-gradient(135deg, #fef3c7 0%, #fde68a 100%);
        color: #d97706;
    }

    .badge-dark {
        background: linear-gradient(135deg, #e5e7eb 0%, #d1d5db 100%);
        color: #374151;
    }

    /* History Table */
    .history-card {
        background: white;
        border-radius: 24px;
        padding: 32px;
        box-shadow: var(--shadow-card);
        margin-top: 30px;
    }

    .history-table {
        width: 100%;
        border-collapse: separate;
        border-spacing: 0 8px;
    }

    .history-table thead th {
        background: #f9fafb;
        padding: 12px 16px;
        text-align: left;
        font-weight: 600;
        color: var(--text-secondary);
        font-size: 0.85rem;
        text-transform: uppercase;
        letter-spacing: 0.5px;
    }

    .history-table thead th:first-child {
        border-radius: 12px 0 0 12px;
    }

    .history-table thead th:last-child {
        border-radius: 0 12px 12px 0;
    }

    .history-table tbody tr {
        background: #f9fafb;
        transition: all 0.3s ease;
    }

    .history-table tbody tr:hover {
        background: #f3f4f6;
        transform: translateX(4px);
    }

    .history-table tbody td {
        padding: 16px;
    }

    .history-table tbody td:first-child {
        border-radius: 12px 0 0 12px;
    }

    .history-table tbody td:last-child {
        border-radius: 0 12px 12px 0;
    }

    /* Sidebar */
    .sidebar-section {
        display: flex;
        flex-direction: column;
        gap: 24px;
    }

    /* Countdown Card */
    .countdown-card {
        background: linear-gradient(135deg, #fef3c7 0%, #fde68a 100%);
        border-radius: 24px;
        padding: 32px;
        text-align: center;
        box-shadow: var(--shadow-card);
        border: 2px solid #fbbf24;
    }

    .countdown-number {
        font-size: 4rem;
        font-weight: 800;
        color: #d97706;
        line-height: 1;
        margin-bottom: 8px;
        text-shadow: 2px 2px 4px rgba(0,0,0,0.1);
    }

    .countdown-label {
        font-size: 1.1rem;
        color: #92400e;
        font-weight: 600;
        margin-bottom: 16px;
    }

    .countdown-date {
        font-size: 0.9rem;
        color: #78350f;
        padding-top: 16px;
        border-top: 2px solid rgba(217, 119, 6, 0.2);
    }

    /* Permanent Ban Card */
    .permanent-card {
        background: linear-gradient(135deg, #1f2937 0%, #111827 100%);
        border-radius: 24px;
        padding: 32px;
        text-align: center;
        box-shadow: var(--shadow-card);
        color: white;
    }

    .permanent-card i {
        font-size: 3rem;
        margin-bottom: 16px;
        opacity: 0.9;
    }

    .permanent-card h3 {
        font-size: 1.3rem;
        font-weight: 700;
        margin-bottom: 8px;
    }

    .permanent-card p {
        opacity: 0.8;
        font-size: 0.9rem;
    }

    /* Action Card */
    .action-card {
        background: white;
        border-radius: 24px;
        padding: 28px;
        box-shadow: var(--shadow-card);
        text-align: center;
    }

    .action-card h3 {
        font-size: 1.2rem;
        font-weight: 700;
        color: var(--text-primary);
        margin-bottom: 12px;
    }

    .action-card p {
        color: var(--text-secondary);
        font-size: 0.9rem;
        margin-bottom: 20px;
        line-height: 1.6;
    }

    .btn-modern {
        display: block;
        width: 100%;
        padding: 14px 24px;
        border-radius: 12px;
        font-weight: 600;
        font-size: 1rem;
        text-decoration: none;
        transition: all 0.3s ease;
        border: none;
        cursor: pointer;
        margin-bottom: 12px;
    }

    .btn-modern:last-child {
        margin-bottom: 0;
    }

    .btn-warning-modern {
        background: linear-gradient(135deg, #fbbf24 0%, #f59e0b 100%);
        color: white;
        box-shadow: 0 4px 12px rgba(251, 191, 36, 0.3);
    }

    .btn-warning-modern:hover {
        transform: translateY(-2px);
        box-shadow: 0 8px 20px rgba(251, 191, 36, 0.4);
        color: white;
        text-decoration: none;
    }

    .btn-secondary-modern {
        background: #f3f4f6;
        color: var(--text-primary);
    }

    .btn-secondary-modern:hover {
        background: #e5e7eb;
        transform: translateY(-2px);
        text-decoration: none;
        color: var(--text-primary);
    }

    /* Help Card */
    .help-card {
        background: white;
        border-radius: 24px;
        padding: 28px;
        box-shadow: var(--shadow-card);
    }

    .help-card h3 {
        font-size: 1.1rem;
        font-weight: 700;
        color: var(--text-primary);
        margin-bottom: 16px;
        display: flex;
        align-items: center;
        gap: 8px;
    }

    .help-card ul {
        list-style: none;
        padding: 0;
        margin: 0;
    }

    .help-card li {
        padding: 10px 0;
        color: var(--text-secondary);
        font-size: 0.9rem;
        display: flex;
        align-items: flex-start;
        gap: 10px;
    }

    .help-card li i {
        color: var(--danger-primary);
        margin-top: 3px;
        flex-shrink: 0;
    }

    /* Animations */
    @@keyframes fadeInDown {
        from {
            opacity: 0;
            transform: translateY(-30px);
        }
        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    @@keyframes fadeInUp {
        from {
            opacity: 0;
            transform: translateY(30px);
        }
        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    @@keyframes pulse {
        0%, 100% {
            transform: scale(1);
        }
        50% {
            transform: scale(1.05);
        }
    }

    /* Responsive */
    @@media (max-width: 1024px) {
        .banned-content-grid {
            grid-template-columns: 1fr;
        }

        .sidebar-section {
            display: grid;
            grid-template-columns: repeat(2, 1fr);
            gap: 24px;
        }
    }

    @@media (max-width: 768px) {
        .banned-container {
            padding: 20px 16px 60px;
        }

        .banned-hero {
            padding: 40px 24px;
        }

        .banned-hero h1 {
            font-size: 2rem;
        }

        .banned-hero p {
            font-size: 1rem;
        }

        .sidebar-section {
            grid-template-columns: 1fr;
        }

        .info-card, .history-card, .action-card, .help-card {
            padding: 24px;
        }

        .countdown-number {
            font-size: 3rem;
        }

        .info-row {
            flex-direction: column;
            gap: 8px;
        }

        .info-label {
            min-width: auto;
        }
    }
</style>

<div class="banned-container">
    <!-- Hero Section -->
    <div class="banned-hero">
        <div class="banned-icon">
            <i class="fas fa-ban"></i>
        </div>
        <h1>Community Access Restricted</h1>
        <p>Your account has been temporarily suspended due to community guideline violations</p>
    </div>

    <!-- Content Grid -->
    <div class="banned-content-grid">
        <!-- Main Content -->
        <div>
            <!-- Ban Information Card -->
            <div class="info-card">
                <h2><i class="fas fa-info-circle"></i> Ban Information</h2>
                
                <div class="info-row">
                    <div class="info-label">Reason</div>
                    <div class="info-value">@Model.BanReason</div>
                </div>

                <div class="info-row">
                    <div class="info-label">Ban Level</div>
                    <div class="info-value">
                        <span class="badge-custom badge-danger">Level @Model.BanLevel</span>
                    </div>
                </div>

                <div class="info-row">
                    <div class="info-label">Total Violations</div>
                    <div class="info-value">
                        <span class="badge-custom badge-warning">@Model.ViolationCount violations</span>
                    </div>
                </div>

                @if (!isPermanent)
                {
                    <div class="info-row">
                        <div class="info-label">Expires On</div>
                        <div class="info-value">@Model.BanExpiresAt.Value.ToString("MMMM dd, yyyy 'at' hh:mm tt UTC")</div>
                    </div>
                }
                else
                {
                    <div class="info-row">
                        <div class="info-label">Duration</div>
                        <div class="info-value">
                            <span class="badge-custom badge-dark">PERMANENT BAN</span>
                        </div>
                    </div>
                }
            </div>

            <!-- Ban History -->
            @if (Model.BanHistory.Any())
            {
                <div class="history-card">
                    <h2><i class="fas fa-history"></i> Ban History</h2>
                    <table class="history-table">
                        <thead>
                            <tr>
                                <th>Date</th>
                                <th>Duration</th>
                                <th>Violations</th>
                                <th>Reason</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var ban in Model.BanHistory.OrderByDescending(b => b.BannedAt))
                            {
                                <tr>
                                    <td>@ban.BannedAt.ToString("MMM dd, yyyy")</td>
                                    <td>
                                        @if (ban.DurationDays == -1)
                                        {
                                            <span class="badge-custom badge-dark">Permanent</span>
                                        }
                                        else
                                        {
                                            <span>@ban.DurationDays days</span>
                                        }
                                    </td>
                                    <td>@ban.ViolationCount</td>
                                    <td><small>@ban.Reason</small></td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>

        <!-- Sidebar -->
        <div class="sidebar-section">
            <!-- Countdown or Permanent Badge -->
            @if (!isPermanent && daysRemaining >= 0)
            {
                <div class="countdown-card">
                    <div class="countdown-number">@daysRemaining</div>
                    <div class="countdown-label">@(daysRemaining == 1 ? "day" : "days") remaining</div>
                    <div class="countdown-date">
                        Access restored on<br/>
                        <strong>@Model.BanExpiresAt.Value.ToString("MMM dd, yyyy")</strong>
                    </div>
                </div>
            }
            else if (isPermanent)
            {
                <div class="permanent-card">
                    <i class="fas fa-infinity"></i>
                    <h3>Permanent Ban</h3>
                    <p>Only an administrator can lift this ban</p>
                </div>
            }

            <!-- Actions -->
            <div class="action-card">
                <h3>Need Help?</h3>
                <p>Submit an appeal to have your case reviewed by our moderation team.</p>
                <a href="/Community/Appeal" class="btn-modern btn-warning-modern">
                    <i class="fas fa-gavel"></i> Submit Appeal
                </a>
                <a href="/" class="btn-modern btn-secondary-modern">
                    <i class="fas fa-home"></i> Return Home
                </a>
            </div>

            <!-- Help Info -->
            <div class="help-card">
                <h3><i class="fas fa-question-circle"></i> What Now?</h3>
                <ul>
                    <li><i class="fas fa-check-circle"></i> Submit an appeal with your explanation</li>
                    @if (!isPermanent)
                    {
                        <li><i class="fas fa-check-circle"></i> Wait for the ban to expire automatically</li>
                    }
                    <li><i class="fas fa-check-circle"></i> Review community guidelines</li>
                    <li><i class="fas fa-check-circle"></i> Avoid future violations</li>
                </ul>
            </div>
        </div>
    </div>
</div>
