@model List<ServConnect.Models.TransportRoute>
@{
    ViewData["Title"] = "TransitConnect - Transport Updates";
    var transportTypes = ServConnect.Models.TransportTypes.All;
    var currentFilter = ViewBag.TransportTypeFilter as string;
    var fromFilter = ViewBag.FromFilter as string;
    var toFilter = ViewBag.ToFilter as string;
    var popularLocations = ViewBag.PopularLocations as List<string> ?? new List<string>();
    var isAuthenticated = ViewBag.IsAuthenticated as bool? ?? false;
}

<style>
    :root {
        --primary: #0EA5E9;
        --primary-dark: #0284C7;
        --primary-light: #38BDF8;
        --accent: #F59E0B;
        --success: #10B981;
        --danger: #EF4444;
        --bg-light: #f0f9ff;
        --bg-card: #ffffff;
        --text-primary: #1e293b;
        --text-secondary: #64748b;
        --border-color: #e2e8f0;
        --shadow-card: 0 4px 20px rgba(0, 0, 0, 0.08);
    }

    .transit-container {
        max-width: 1400px;
        margin: 0 auto;
        padding: 30px 20px 80px;
    }

    .back-btn {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        padding: 10px 20px;
        background: white;
        color: var(--text-primary);
        border-radius: 50px;
        text-decoration: none;
        font-weight: 500;
        box-shadow: var(--shadow-card);
        border: 1px solid var(--border-color);
        transition: all 0.3s ease;
        margin-bottom: 24px;
    }

    .back-btn:hover {
        transform: translateX(-5px);
        color: var(--primary);
        border-color: var(--primary);
        text-decoration: none;
    }

    .page-header {
        text-align: center;
        margin-bottom: 40px;
    }

    .page-header h1 {
        font-size: 2.8rem;
        font-weight: 800;
        background: linear-gradient(135deg, var(--primary) 0%, var(--primary-dark) 100%);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        margin-bottom: 12px;
    }

    .page-header p {
        color: var(--text-secondary);
        font-size: 1.1rem;
        max-width: 600px;
        margin: 0 auto;
    }

    .header-actions {
        display: flex;
        justify-content: center;
        gap: 16px;
        margin-top: 24px;
    }

    .btn-add-route {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        padding: 10px 24px;
        background: linear-gradient(135deg, var(--primary) 0%, var(--primary-dark) 100%);
        color: white;
        border-radius: 50px;
        font-weight: 600;
        text-decoration: none;
        box-shadow: 0 8px 25px rgba(14, 165, 233, 0.3);
        transition: all 0.3s ease;
    }

    .btn-add-route:hover {
        transform: translateY(-3px);
        box-shadow: 0 12px 35px rgba(14, 165, 233, 0.4);
        color: white;
        text-decoration: none;
    }

    .btn-my-routes {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        padding: 10px 24px;
        background: white;
        color: var(--primary);
        border: 2px solid var(--primary);
        border-radius: 50px;
        font-weight: 600;
        text-decoration: none;
        transition: all 0.3s ease;
    }

    .btn-my-routes:hover {
        background: var(--primary);
        color: white;
        text-decoration: none;
    }

    /* Search Section */
    .search-section {
        background: white;
        border-radius: 20px;
        padding: 30px;
        box-shadow: var(--shadow-card);
        margin-bottom: 30px;
    }

    .search-form {
        display: grid;
        grid-template-columns: 1fr 1fr 200px auto;
        gap: 16px;
        align-items: end;
    }

    .form-group label {
        display: block;
        font-weight: 600;
        color: var(--text-primary);
        margin-bottom: 8px;
        font-size: 0.9rem;
    }

    .form-control {
        width: 100%;
        padding: 12px 16px;
        border: 2px solid var(--border-color);
        border-radius: 12px;
        font-size: 1rem;
        transition: all 0.3s ease;
    }

    .form-control:focus {
        outline: none;
        border-color: var(--primary);
        box-shadow: 0 0 0 4px rgba(14, 165, 233, 0.1);
    }

    .btn-search {
        padding: 12px 28px;
        background: linear-gradient(135deg, var(--primary) 0%, var(--primary-dark) 100%);
        color: white;
        border: none;
        border-radius: 12px;
        font-weight: 600;
        cursor: pointer;
        transition: all 0.3s ease;
        height: fit-content;
    }

    .btn-search:hover {
        transform: translateY(-2px);
        box-shadow: 0 8px 20px rgba(14, 165, 233, 0.3);
    }

    /* Transport Type Filters */
    .transport-filters {
        display: flex;
        flex-wrap: wrap;
        gap: 12px;
        margin-bottom: 30px;
    }

    .filter-chip {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        padding: 10px 20px;
        background: white;
        border: 2px solid var(--border-color);
        border-radius: 50px;
        color: var(--text-secondary);
        text-decoration: none;
        font-weight: 500;
        transition: all 0.3s ease;
    }

    .filter-chip:hover, .filter-chip.active {
        background: var(--primary);
        border-color: var(--primary);
        color: white;
        text-decoration: none;
    }

    .filter-chip i {
        font-size: 1.1rem;
    }

    /* Results Header */
    .results-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 24px;
    }

    .results-count {
        font-size: 1.1rem;
        color: var(--text-secondary);
    }

    .results-count strong {
        color: var(--primary);
    }

    /* Route Cards Grid */
    .routes-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(380px, 1fr));
        gap: 24px;
    }

    .route-card {
        background: white;
        border-radius: 20px;
        overflow: hidden;
        box-shadow: var(--shadow-card);
        transition: all 0.4s ease;
        text-decoration: none;
        color: inherit;
        display: flex;
        flex-direction: column;
    }

    .route-card:hover {
        transform: translateY(-8px);
        box-shadow: 0 20px 40px rgba(0, 0, 0, 0.12);
        text-decoration: none;
        color: inherit;
    }

    .route-card-header {
        padding: 20px;
        background: linear-gradient(135deg, var(--bg-light) 0%, #e0f2fe 100%);
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
    }

    .transport-badge {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        padding: 6px 14px;
        background: white;
        border-radius: 50px;
        font-size: 0.85rem;
        font-weight: 600;
        color: var(--primary);
        box-shadow: 0 2px 8px rgba(0, 0, 0, 0.08);
    }

    .reliability-badge {
        display: flex;
        flex-direction: column;
        align-items: center;
        padding: 8px 12px;
        background: white;
        border-radius: 12px;
        box-shadow: 0 2px 8px rgba(0, 0, 0, 0.08);
    }

    .reliability-score {
        font-size: 1.3rem;
        font-weight: 700;
        color: var(--success);
    }

    .reliability-label {
        font-size: 0.7rem;
        color: var(--text-secondary);
        text-transform: uppercase;
    }

    .route-card-body {
        padding: 24px;
        flex: 1;
    }

    .route-name {
        font-size: 1.3rem;
        font-weight: 700;
        color: var(--text-primary);
        margin-bottom: 4px;
    }

    .route-number {
        font-size: 0.9rem;
        color: var(--text-secondary);
        margin-bottom: 16px;
    }

    .route-path {
        display: flex;
        align-items: center;
        gap: 12px;
        margin-bottom: 16px;
    }

    .location {
        flex: 1;
        padding: 12px;
        background: var(--bg-light);
        border-radius: 10px;
        text-align: center;
    }

    .location-label {
        font-size: 0.75rem;
        color: var(--text-secondary);
        text-transform: uppercase;
        margin-bottom: 4px;
    }

    .location-name {
        font-weight: 600;
        color: var(--text-primary);
    }

    .route-arrow {
        color: var(--primary);
        font-size: 1.2rem;
    }

    .route-timings {
        display: flex;
        gap: 20px;
        margin-bottom: 16px;
    }

    .timing-item {
        display: flex;
        align-items: center;
        gap: 8px;
        color: var(--text-secondary);
        font-size: 0.9rem;
    }

    .timing-item i {
        color: var(--primary);
    }

    .timing-item strong {
        color: var(--text-primary);
    }

    .route-features {
        display: flex;
        flex-wrap: wrap;
        gap: 8px;
    }

    .feature-tag {
        display: inline-flex;
        align-items: center;
        gap: 4px;
        padding: 4px 10px;
        background: #f1f5f9;
        border-radius: 50px;
        font-size: 0.8rem;
        color: var(--text-secondary);
    }

    .feature-tag i {
        color: var(--success);
    }

    .route-card-footer {
        padding: 16px 24px;
        border-top: 1px solid var(--border-color);
        display: flex;
        justify-content: space-between;
        align-items: center;
    }

    .vote-info {
        display: flex;
        align-items: center;
        gap: 16px;
    }

    .vote-item {
        display: flex;
        align-items: center;
        gap: 6px;
        color: var(--text-secondary);
        font-size: 0.9rem;
    }

    .vote-item.upvote { color: var(--success); }
    .vote-item.downvote { color: var(--danger); }

    .view-details {
        color: var(--primary);
        font-weight: 600;
        font-size: 0.9rem;
        display: flex;
        align-items: center;
        gap: 6px;
    }

    /* Empty State */
    .empty-state {
        text-align: center;
        padding: 60px 20px;
        background: white;
        border-radius: 20px;
        box-shadow: var(--shadow-card);
    }

    .empty-state i {
        font-size: 4rem;
        color: var(--primary);
        opacity: 0.5;
        margin-bottom: 20px;
    }

    .empty-state h3 {
        font-size: 1.5rem;
        color: var(--text-primary);
        margin-bottom: 8px;
    }

    .empty-state p {
        color: var(--text-secondary);
        margin-bottom: 24px;
    }

    /* Info Banner */
    .info-banner {
        background: linear-gradient(135deg, #fef3c7 0%, #fde68a 100%);
        border-radius: 16px;
        padding: 20px 24px;
        display: flex;
        align-items: center;
        gap: 16px;
        margin-bottom: 30px;
    }

    .info-banner i {
        font-size: 2rem;
        color: #D97706;
    }

    .info-banner-content h4 {
        color: #92400E;
        font-weight: 600;
        margin-bottom: 4px;
    }

    .info-banner-content p {
        color: #B45309;
        font-size: 0.9rem;
        margin: 0;
    }

    /* Responsive */
    @@media (max-width: 992px) {
        .search-form {
            grid-template-columns: 1fr 1fr;
        }

        .routes-grid {
            grid-template-columns: 1fr;
        }
    }

    @@media (max-width: 768px) {
        .page-header h1 {
            font-size: 2rem;
        }

        .search-form {
            grid-template-columns: 1fr;
        }

        .header-actions {
            flex-direction: column;
        }

        .route-timings {
            flex-direction: column;
            gap: 8px;
        }
    }
</style>

<div class="transit-container">
    <a href="/Home/ExploreServices" class="back-btn">
        <i class="fas fa-arrow-left"></i> Back to Services
    </a>

    <div class="page-header">
        <h1><i class="fas fa-bus-alt"></i> TransitConnect</h1>
        <p>Community-powered bus timings and routes. Find bus schedules and contribute to help fellow travelers!</p>
        
        @if (isAuthenticated)
        {
            <div class="header-actions">
                <a href="@Url.Action("Add")" class="btn-add-route">
                    <i class="fas fa-plus"></i> Add New Route
                </a>
                <a href="@Url.Action("MyRoutes")" class="btn-my-routes">
                    <i class="fas fa-user"></i> My Routes
                </a>
            </div>
        }
        else
        {
            <div class="header-actions">
                <a href="/Account/Login?returnUrl=/TransitConnect" class="btn-add-route">
                    <i class="fas fa-sign-in-alt"></i> Login to Contribute
                </a>
            </div>
        }
    </div>

    <!-- Info Banner -->
    <div class="info-banner">
        <i class="fas fa-lightbulb"></i>
        <div class="info-banner-content">
            <h4>Community-Powered Updates</h4>
            <p>All routes are contributed by users like you. Upvote accurate information and downvote outdated ones. Routes with too many downvotes are automatically removed!</p>
        </div>
    </div>

    <!-- Search Section -->
    <div class="search-section">
        <form method="get" class="search-form">
            <div class="form-group">
                <label><i class="fas fa-map-marker-alt"></i> From</label>
                <input type="text" name="from" class="form-control" placeholder="Starting point..." 
                       value="@fromFilter" list="locationsList" autocomplete="off">
            </div>
            <div class="form-group">
                <label><i class="fas fa-flag-checkered"></i> To</label>
                <input type="text" name="to" class="form-control" placeholder="Destination..." 
                       value="@toFilter" list="locationsList" autocomplete="off">
            </div>
            <button type="submit" class="btn-search">
                <i class="fas fa-search"></i> Search
            </button>
        </form>

        <datalist id="locationsList">
            @foreach (var loc in popularLocations)
            {
                <option value="@loc"></option>
            }
        </datalist>
    </div>



    <!-- Results -->
    <div class="results-header">
        <div class="results-count">
            Found <strong>@ViewBag.TotalCount</strong> routes
            @if (!string.IsNullOrEmpty(fromFilter) || !string.IsNullOrEmpty(toFilter))
            {
                <span>
                    @if (!string.IsNullOrEmpty(fromFilter)) { <text>from <strong>@fromFilter</strong></text> }
                    @if (!string.IsNullOrEmpty(toFilter)) { <text>to <strong>@toFilter</strong></text> }
                </span>
            }
        </div>
    </div>

    @if (Model.Count == 0)
    {
        <div class="empty-state">
            <i class="fas fa-route"></i>
            <h3>No routes found</h3>
            <p>Be the first to add a route for this search!</p>
            @if (isAuthenticated)
            {
                <a href="@Url.Action("Add")" class="btn-add-route">
                    <i class="fas fa-plus"></i> Add New Route
                </a>
            }
        </div>
    }
    else
    {
        <div class="routes-grid">
            @foreach (var route in Model)
            {
                <a href="@Url.Action("Details", new { id = route.Id })" class="route-card">
                    <div class="route-card-header">
                        <div class="transport-badge">
                            <i class="fas fa-bus"></i>
                            Bus
                        </div>
                        <div class="reliability-badge">
                            <span class="reliability-score">@route.ReliabilityPercentage%</span>
                            <span class="reliability-label">Reliable</span>
                        </div>
                    </div>
                    
                    <div class="route-card-body">
                        <h3 class="route-name">@route.TransportName</h3>
                        @if (!string.IsNullOrEmpty(route.RouteNumber))
                        {
                            <p class="route-number">Route: @route.RouteNumber</p>
                        }
                        
                        <div class="route-path">
                            <div class="location">
                                <div class="location-label">From</div>
                                <div class="location-name">@route.StartLocation</div>
                            </div>
                            <i class="fas fa-arrow-right route-arrow"></i>
                            <div class="location">
                                <div class="location-label">To</div>
                                <div class="location-name">@route.EndLocation</div>
                            </div>
                        </div>
                        
                        <div class="route-timings">
                            <div class="timing-item">
                                <i class="fas fa-clock"></i>
                                Departs: <strong>@route.DepartureTime</strong>
                            </div>
                            @if (!string.IsNullOrEmpty(route.Duration))
                            {
                                <div class="timing-item">
                                    <i class="fas fa-hourglass-half"></i>
                                    Duration: <strong>@route.Duration</strong>
                                </div>
                            }
                        </div>
                        
                        <div class="route-features">
                            @if (route.IsACAvailable)
                            {
                                <span class="feature-tag"><i class="fas fa-snowflake"></i> AC</span>
                            }
                            @if (route.IsWheelchairAccessible)
                            {
                                <span class="feature-tag"><i class="fas fa-wheelchair"></i> Accessible</span>
                            }
                            @if (route.IsExpressService)
                            {
                                <span class="feature-tag"><i class="fas fa-bolt"></i> Express</span>
                            }
                            @if (route.IntermediateStops.Count > 0)
                            {
                                <span class="feature-tag"><i class="fas fa-map-signs"></i> @route.IntermediateStops.Count stops</span>
                            }
                        </div>
                    </div>
                    
                    <div class="route-card-footer">
                        <div class="vote-info">
                            <span class="vote-item upvote">
                                <i class="fas fa-thumbs-up"></i> @route.Upvotes
                            </span>
                            <span class="vote-item downvote">
                                <i class="fas fa-thumbs-down"></i> @route.Downvotes
                            </span>
                        </div>
                        <span class="view-details">
                            View Details <i class="fas fa-chevron-right"></i>
                        </span>
                    </div>
                </a>
            }
        </div>
    }
</div>
