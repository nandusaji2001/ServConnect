@model ServConnect.Models.TransportRoute
@{
    ViewData["Title"] = "Add New Route - TransitConnect";
    var transportTypes = ServConnect.Models.TransportTypes.All;
    var serviceDays = ServConnect.Models.ServiceDays.All;
    var frequencies = ServConnect.Models.FrequencyTypes.All;
    var userDistrict = ViewBag.UserDistrict as string;
}

<style>
    :root {
        --primary: #0EA5E9;
        --primary-dark: #0284C7;
        --success: #10B981;
        --danger: #EF4444;
        --bg-light: #f0f9ff;
        --text-primary: #1e293b;
        --text-secondary: #64748b;
        --border-color: #e2e8f0;
        --shadow-card: 0 4px 20px rgba(0, 0, 0, 0.08);
    }

    .add-container {
        max-width: 900px;
        margin: 0 auto;
        padding: 30px 20px 80px;
    }

    .back-btn {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        padding: 10px 20px;
        background: white;
        color: var(--text-primary);
        border-radius: 50px;
        text-decoration: none;
        font-weight: 500;
        box-shadow: var(--shadow-card);
        border: 1px solid var(--border-color);
        transition: all 0.3s ease;
        margin-bottom: 24px;
    }

    .back-btn:hover {
        transform: translateX(-5px);
        color: var(--primary);
        border-color: var(--primary);
        text-decoration: none;
    }

    .page-header {
        text-align: center;
        margin-bottom: 40px;
    }

    .page-header h1 {
        font-size: 2.2rem;
        font-weight: 700;
        color: var(--text-primary);
        margin-bottom: 12px;
    }

    .page-header p {
        color: var(--text-secondary);
        font-size: 1rem;
    }

    .form-card {
        background: white;
        border-radius: 24px;
        padding: 40px;
        box-shadow: var(--shadow-card);
    }

    .form-section {
        margin-bottom: 36px;
    }

    .section-header {
        display: flex;
        align-items: center;
        gap: 12px;
        margin-bottom: 24px;
        padding-bottom: 12px;
        border-bottom: 2px solid var(--bg-light);
    }

    .section-header i {
        width: 40px;
        height: 40px;
        background: var(--bg-light);
        border-radius: 12px;
        display: flex;
        align-items: center;
        justify-content: center;
        color: var(--primary);
        font-size: 1.1rem;
    }

    .section-header h3 {
        font-size: 1.2rem;
        font-weight: 600;
        color: var(--text-primary);
        margin: 0;
    }

    .form-row {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
        gap: 20px;
        margin-bottom: 20px;
    }

    .form-group {
        margin-bottom: 0;
    }

    .form-group label {
        display: block;
        font-weight: 600;
        color: var(--text-primary);
        margin-bottom: 8px;
        font-size: 0.9rem;
    }

    .form-group label .required {
        color: var(--danger);
    }

    .form-control {
        width: 100%;
        padding: 14px 16px;
        border: 2px solid var(--border-color);
        border-radius: 12px;
        font-size: 1rem;
        transition: all 0.3s ease;
        background: white;
    }

    .form-control:focus {
        outline: none;
        border-color: var(--primary);
        box-shadow: 0 0 0 4px rgba(14, 165, 233, 0.1);
    }

    .form-control.is-invalid {
        border-color: var(--danger);
    }

    textarea.form-control {
        resize: vertical;
        min-height: 100px;
    }

    .form-hint {
        font-size: 0.8rem;
        color: var(--text-secondary);
        margin-top: 6px;
    }

    .form-text-error {
        font-size: 0.8rem;
        color: var(--danger);
        margin-top: 6px;
    }

    /* Checkbox Grid */
    .checkbox-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
        gap: 12px;
    }

    .checkbox-item {
        display: flex;
        align-items: center;
        gap: 12px;
        padding: 14px 16px;
        background: var(--bg-light);
        border-radius: 12px;
        cursor: pointer;
        transition: all 0.3s ease;
        border: 2px solid transparent;
    }

    .checkbox-item:hover {
        background: #e0f2fe;
    }

    .checkbox-item input[type="checkbox"] {
        width: 20px;
        height: 20px;
        accent-color: var(--primary);
    }

    .checkbox-item.checked {
        background: #e0f2fe;
        border-color: var(--primary);
    }

    .checkbox-item label {
        margin: 0;
        cursor: pointer;
        display: flex;
        align-items: center;
        gap: 8px;
    }

    .checkbox-item label i {
        color: var(--primary);
    }

    /* Transport Type Selector */
    .transport-selector {
        display: flex;
        flex-wrap: wrap;
        gap: 12px;
    }

    .transport-option {
        flex: 1;
        min-width: 100px;
    }

    .transport-option input[type="radio"] {
        display: none;
    }

    .transport-option label {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 8px;
        padding: 20px;
        background: var(--bg-light);
        border: 2px solid transparent;
        border-radius: 16px;
        cursor: pointer;
        transition: all 0.3s ease;
    }

    .transport-option label i {
        font-size: 1.8rem;
        color: var(--text-secondary);
    }

    .transport-option label span {
        font-weight: 600;
        color: var(--text-secondary);
    }

    .transport-option input[type="radio"]:checked + label {
        background: #e0f2fe;
        border-color: var(--primary);
    }

    .transport-option input[type="radio"]:checked + label i,
    .transport-option input[type="radio"]:checked + label span {
        color: var(--primary);
    }

    /* Submit Button */
    .form-actions {
        display: flex;
        gap: 16px;
        justify-content: flex-end;
        margin-top: 30px;
        padding-top: 30px;
        border-top: 2px solid var(--bg-light);
    }

    .btn-submit {
        display: inline-flex;
        align-items: center;
        gap: 10px;
        padding: 16px 40px;
        background: linear-gradient(135deg, var(--primary) 0%, var(--primary-dark) 100%);
        color: white;
        border: none;
        border-radius: 50px;
        font-size: 1rem;
        font-weight: 600;
        cursor: pointer;
        transition: all 0.3s ease;
        box-shadow: 0 8px 25px rgba(14, 165, 233, 0.3);
    }

    .btn-submit:hover {
        transform: translateY(-3px);
        box-shadow: 0 12px 35px rgba(14, 165, 233, 0.4);
    }

    .btn-cancel {
        display: inline-flex;
        align-items: center;
        gap: 10px;
        padding: 16px 30px;
        background: white;
        color: var(--text-secondary);
        border: 2px solid var(--border-color);
        border-radius: 50px;
        font-size: 1rem;
        font-weight: 600;
        text-decoration: none;
        transition: all 0.3s ease;
    }

    .btn-cancel:hover {
        border-color: var(--danger);
        color: var(--danger);
        text-decoration: none;
    }

    /* Info Box */
    .info-box {
        background: linear-gradient(135deg, #fef3c7 0%, #fde68a 100%);
        border-radius: 16px;
        padding: 20px;
        display: flex;
        align-items: flex-start;
        gap: 16px;
        margin-bottom: 30px;
    }

    .info-box i {
        font-size: 1.5rem;
        color: #D97706;
        margin-top: 2px;
    }

    .info-box-content h4 {
        color: #92400E;
        font-weight: 600;
        margin-bottom: 6px;
    }

    .info-box-content p {
        color: #B45309;
        font-size: 0.9rem;
        margin: 0;
        line-height: 1.5;
    }

    /* Validation Summary */
    .validation-summary {
        background: #fee2e2;
        border: 1px solid #fecaca;
        border-radius: 12px;
        padding: 16px 20px;
        margin-bottom: 24px;
    }

    .validation-summary ul {
        margin: 0;
        padding-left: 20px;
        color: #991B1B;
    }

    /* Responsive */
    @@media (max-width: 768px) {
        .form-card {
            padding: 24px;
        }

        .transport-selector {
            flex-direction: column;
        }

        .form-actions {
            flex-direction: column;
        }

        .btn-submit, .btn-cancel {
            width: 100%;
            justify-content: center;
        }
    }
</style>

<div class="add-container">
    <a href="@Url.Action("Index")" class="back-btn">
        <i class="fas fa-arrow-left"></i> Back to Routes
    </a>

    <div class="page-header">
        <h1><i class="fas fa-plus-circle"></i> Add New Transport Route</h1>
        <p>Share transportation information to help fellow travelers in your community</p>
    </div>

    <div class="info-box">
        <i class="fas fa-lightbulb"></i>
        <div class="info-box-content">
            <h4>Community Guidelines</h4>
            <p>Please ensure the information you provide is accurate. Routes with inaccurate information may be removed by community voting. Your contribution helps thousands of commuters!</p>
        </div>
    </div>

    @if (!ViewData.ModelState.IsValid)
    {
        <div class="validation-summary">
            <ul>
                @foreach (var error in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                {
                    <li>@error.ErrorMessage</li>
                }
            </ul>
        </div>
    }

    <form method="post" class="form-card" asp-action="Add">
        @Html.AntiForgeryToken()

        <input type="hidden" name="TransportType" value="Bus">

        <!-- Basic Information Section -->
        <div class="form-section">
            <div class="section-header">
                <i class="fas fa-info-circle"></i>
                <h3>Basic Information</h3>
            </div>
            <div class="form-row">
                <div class="form-group">
                    <label>Bus Name <span class="required">*</span></label>
                    <input type="text" class="form-control" name="TransportName" value="@Model?.TransportName" 
                           placeholder="e.g., KSRTC Super Fast, Private Bus" required>
                    <span class="form-hint">Name of the bus service</span>
                </div>
                <div class="form-group">
                    <label>Route Number</label>
                    <input type="text" class="form-control" name="RouteNumber" value="@Model?.RouteNumber" 
                           placeholder="e.g., 347, KK Express">
                    <span class="form-hint">Bus route number (if applicable)</span>
                </div>
            </div>
        </div>

        <!-- Route Details Section -->
        <div class="form-section">
            <div class="section-header">
                <i class="fas fa-route"></i>
                <h3>Route Details</h3>
            </div>
            <div class="form-row">
                <div class="form-group">
                    <label>Starting Location <span class="required">*</span></label>
                    <input type="text" class="form-control" name="StartLocation" value="@Model?.StartLocation" 
                           placeholder="e.g., Ernakulam South" required>
                </div>
                <div class="form-group">
                    <label>Starting Point Details</label>
                    <input type="text" class="form-control" name="StartLocationDetails" value="@Model?.StartLocationDetails" 
                           placeholder="e.g., Bus Stand, Platform 3">
                </div>
            </div>
            <div class="form-row">
                <div class="form-group">
                    <label>Destination <span class="required">*</span></label>
                    <input type="text" class="form-control" name="EndLocation" value="@Model?.EndLocation" 
                           placeholder="e.g., Kozhikode" required>
                </div>
                <div class="form-group">
                    <label>Destination Details</label>
                    <input type="text" class="form-control" name="EndLocationDetails" value="@Model?.EndLocationDetails" 
                           placeholder="e.g., KSRTC Bus Stand">
                </div>
            </div>
            <div class="form-group">
                <label>Intermediate Stops</label>
                <input type="text" class="form-control" name="intermediateStopsText" 
                       placeholder="e.g., Thrissur, Palakkad, Malappuram (comma separated)">
                <span class="form-hint">Enter major stops separated by commas</span>
            </div>
        </div>

        <!-- Timing Section -->
        <div class="form-section">
            <div class="section-header">
                <i class="fas fa-clock"></i>
                <h3>Timings & Schedule</h3>
            </div>
            <div class="form-row">
                <div class="form-group">
                    <label>Departure Time <span class="required">*</span></label>
                    <input type="time" class="form-control" name="DepartureTime" value="@Model?.DepartureTime" required>
                </div>
                <div class="form-group">
                    <label>Arrival Time <span class="required">*</span></label>
                    <input type="time" class="form-control" name="ArrivalTime" value="@Model?.ArrivalTime" required>
                </div>
                <div class="form-group">
                    <label>Duration</label>
                    <input type="text" class="form-control" name="Duration" value="@Model?.Duration" 
                           placeholder="e.g., 4 hours 30 mins">
                </div>
            </div>
            <div class="form-row">
                <div class="form-group">
                    <label>Service Days</label>
                    <select class="form-control" name="ServiceDays">
                        @foreach (var day in serviceDays)
                        {
                            if (Model?.ServiceDays == day)
                            {
                                <option value="@day" selected>@day</option>
                            }
                            else
                            {
                                <option value="@day">@day</option>
                            }
                        }
                    </select>
                </div>
                <div class="form-group">
                    <label>Frequency</label>
                    <select class="form-control" name="Frequency">
                        <option value="">Select frequency...</option>
                        @foreach (var freq in frequencies)
                        {
                            if (Model?.Frequency == freq)
                            {
                                <option value="@freq" selected>@freq</option>
                            }
                            else
                            {
                                <option value="@freq">@freq</option>
                            }
                        }
                    </select>
                </div>
            </div>
        </div>

        <!-- Fare Section -->
        <div class="form-section">
            <div class="section-header">
                <i class="fas fa-rupee-sign"></i>
                <h3>Fare Information</h3>
            </div>
            <div class="form-row">
                <div class="form-group">
                    <label>Approximate Fare (₹)</label>
                    <input type="number" class="form-control" name="ApproxFare" value="@Model?.ApproxFare" 
                           placeholder="e.g., 350" min="0" step="1">
                </div>
                <div class="form-group">
                    <label>Fare Details</label>
                    <input type="text" class="form-control" name="FareDetails" value="@Model?.FareDetails" 
                           placeholder="e.g., AC: ₹450, Non-AC: ₹350">
                </div>
            </div>
        </div>

        <!-- Features Section -->
        <div class="form-section">
            <div class="section-header">
                <i class="fas fa-star"></i>
                <h3>Features & Amenities</h3>
            </div>
            <div class="checkbox-grid">
                <div class="checkbox-item" onclick="toggleCheckbox(this)">
                    <input type="checkbox" name="IsACAvailable" value="true" id="isAC" @(Model?.IsACAvailable == true ? "checked" : "")>
                    <label for="isAC">
                        <i class="fas fa-snowflake"></i> AC Available
                    </label>
                </div>
                <div class="checkbox-item" onclick="toggleCheckbox(this)">
                    <input type="checkbox" name="IsWheelchairAccessible" value="true" id="isAccessible" @(Model?.IsWheelchairAccessible == true ? "checked" : "")>
                    <label for="isAccessible">
                        <i class="fas fa-wheelchair"></i> Wheelchair Accessible
                    </label>
                </div>
                <div class="checkbox-item" onclick="toggleCheckbox(this)">
                    <input type="checkbox" name="HasWifi" value="true" id="hasWifi" @(Model?.HasWifi == true ? "checked" : "")>
                    <label for="hasWifi">
                        <i class="fas fa-wifi"></i> WiFi Available
                    </label>
                </div>
                <div class="checkbox-item" onclick="toggleCheckbox(this)">
                    <input type="checkbox" name="IsExpressService" value="true" id="isExpress" @(Model?.IsExpressService == true ? "checked" : "")>
                    <label for="isExpress">
                        <i class="fas fa-bolt"></i> Express Service
                    </label>
                </div>
                <div class="checkbox-item" onclick="toggleCheckbox(this)">
                    <input type="checkbox" name="IsPeakHourService" value="true" id="isPeak" @(Model?.IsPeakHourService == true ? "checked" : "")>
                    <label for="isPeak">
                        <i class="fas fa-sun"></i> Peak Hours Only
                    </label>
                </div>
            </div>
        </div>

        <!-- Additional Notes Section -->
        <div class="form-section">
            <div class="section-header">
                <i class="fas fa-sticky-note"></i>
                <h3>Additional Information</h3>
            </div>
            <div class="form-group">
                <label>Additional Notes</label>
                <textarea class="form-control" name="AdditionalNotes" rows="3" 
                          placeholder="Any other useful information for travelers (e.g., booking tips, best seats, etc.)">@Model?.AdditionalNotes</textarea>
            </div>
        </div>

        <div class="form-actions">
            <a href="@Url.Action("Index")" class="btn-cancel">
                <i class="fas fa-times"></i> Cancel
            </a>
            <button type="submit" class="btn-submit">
                <i class="fas fa-plus"></i> Add Route
            </button>
        </div>
    </form>
</div>

<script>
    function toggleCheckbox(element) {
        const checkbox = element.querySelector('input[type="checkbox"]');
        checkbox.checked = !checkbox.checked;
        element.classList.toggle('checked', checkbox.checked);
    }

    // Initialize checked state
    document.querySelectorAll('.checkbox-item input[type="checkbox"]:checked').forEach(checkbox => {
        checkbox.closest('.checkbox-item').classList.add('checked');
    });
</script>
